---
import { SITE_TITLE, SOCIAL_LINKS } from '../consts';
import Logo from './Logo.astro';
const today = new Date();
---

<footer>
	<div class="footer-content">
		<div class="brand-section">
			<Logo variant="stamp" class="footer-stamp" />
			<p>Honest car maintenance, cost, and buying guides for the Philippines. We document machines, not just list them.</p>
			{SOCIAL_LINKS.length > 0 && (
				<div class="social-links">
					{SOCIAL_LINKS.map((url) => {
						const isFacebook = url.includes('facebook.com');
						const isInstagram = url.includes('instagram.com');
						const label = isFacebook ? 'Facebook' : isInstagram ? 'Instagram' : 'Social';
						return (
							<a href={url} target="_blank" rel="noopener noreferrer" aria-label={`Apex Engine on ${label}`}>
								{isFacebook && (
									<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.51 1.49-3.9 3.77-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.89h2.78l-.44 2.91h-2.34V22c4.78-.76 8.44-4.92 8.44-9.94z"/></svg>
								)}
								{isInstagram && (
									<svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c2.72 0 3.06.01 4.12.06 1.06.05 1.79.22 2.43.47.66.26 1.21.6 1.76 1.15.55.55.9 1.1 1.15 1.76.25.64.42 1.37.47 2.43.05 1.06.06 1.4.06 4.12s-.01 3.06-.06 4.12c-.05 1.06-.22 1.79-.47 2.43a4.9 4.9 0 0 1-1.15 1.76 4.9 4.9 0 0 1-1.76 1.15c-.64.25-1.37.42-2.43.47-1.06.05-1.4.06-4.12.06s-3.06-.01-4.12-.06c-1.06-.05-1.79-.22-2.43-.47a4.9 4.9 0 0 1-1.76-1.15 4.9 4.9 0 0 1-1.15-1.76c-.25-.64-.42-1.37-.47-2.43C2.01 15.06 2 14.72 2 12s.01-3.06.06-4.12c.05-1.06.22-1.79.47-2.43.26-.66.6-1.21 1.15-1.76a4.9 4.9 0 0 1 1.76-1.15c.64-.25 1.37-.42 2.43-.47C8.94 2.01 9.28 2 12 2zm0 5a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm0 8.25a3.25 3.25 0 1 1 0-6.5 3.25 3.25 0 0 1 0 6.5zm5.2-8.45a1.17 1.17 0 1 1-2.34 0 1.17 1.17 0 0 1 2.34 0z"/></svg>
								)}
							</a>
						);
					})}
				</div>
			)}
		</div>
		<nav class="footer-nav">
			<div class="nav-group">
				<h3>Marketplace</h3>
				<ul>
					<li><a href="/listings">Inventory</a></li>
					<li><a href="/models">Model Catalog</a></li>
					<li><a href="/contact">Inquire Sourcing</a></li>
				</ul>
			</div>
			<div class="nav-group">
				<h3>Editorial</h3>
				<ul>
					<li><a href="/blog">News & Reviews</a></li>
					<li><a href="/models">JDM Buying Guides</a></li>
					<li><a href="/blog/the-silent-surge-south-luzon-ev-era">EV Tech Features</a></li>
				</ul>
			</div>
			<div class="nav-group">
				<h3>Company</h3>
				<ul>
					<li><a href="/about">About Us</a></li>
					<li><a href="/contact">Contact Info</a></li>
				</ul>
			</div>
			<div class="nav-group">
				<h3>Legal</h3>
				<ul>
					<li><a href="/privacy">Privacy Policy</a></li>
					<li><a href="/terms">Terms &amp; Conditions</a></li>
				</ul>
			</div>
		</nav>
	</div>
	<div class="footer-bottom">
		&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.
	</div>
</footer>

<style>
	footer {
		padding: 4em 1em 2em;
		background: var(--mica-dark);
		color: var(--paper-off);
		border-top: 4px solid var(--accent-color);
	}
	.footer-content {
		max-width: 1400px;
		margin: 0 auto;
		display: grid;
		gap: 3em;
	}
	@media (min-width: 768px) {
		.footer-content {
			grid-template-columns: 1fr 2fr;
		}
	}
	.brand-section h2 {
		color: var(--paper);
		margin-bottom: 0.5em;
		text-transform: uppercase;
		font-size: 1.5em;
		letter-spacing: -0.02em;
	}
	.brand-section :global(.footer-stamp) {
		width: 116px;
		height: 116px;
		margin-bottom: 1.25em;
		color: var(--paper);
	}
	.brand-section p {
		color: var(--metal-gray-light);
		max-width: 30ch;
		line-height: 1.6;
		font-size: 0.9rem;
	}
	.social-links {
		display: flex;
		gap: 1em;
		margin-top: 1.25em;
	}
	.social-links a {
		color: var(--metal-gray-light);
		display: inline-flex;
	}
	.social-links a:hover {
		color: var(--accent-color);
	}
	.footer-nav {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
		gap: 2em;
	}
	.nav-group h3 {
		color: var(--paper);
		font-size: 0.9rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 1.5em;
	}
	.nav-group ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.nav-group li {
		margin-bottom: 0.75em;
	}
	.nav-group a {
		color: var(--metal-gray-light);
		text-decoration: none;
		font-size: 0.95rem;
	}
	.nav-group a:hover {
		color: var(--accent-color);
	}
	.footer-bottom {
		max-width: 1400px;
		margin: 4em auto 0;
		padding-top: 2em;
		border-top: 1px solid var(--black-mica-2);
		text-align: center;
		font-size: 0.85rem;
		color: var(--metal-gray);
	}
	.license {
		margin-top: 0.5em;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}
</style>
