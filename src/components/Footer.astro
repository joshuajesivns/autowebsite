---
import { SITE_TITLE } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-content">
		<div class="brand-section">
			<h2>{SITE_TITLE}</h2>
			<p>Documenting machines, not just listing them. Verified automotive imports and technical guides for the Philippines.</p>
		</div>
		<nav class="footer-nav">
			<div class="nav-group">
				<h3>Marketplace</h3>
				<ul>
					<li><a href="/listings">Inventory</a></li>
					<li><a href="/listings?category=kei-truck">Kei Trucks</a></li>
					<li><a href="/listings?category=sports">Sports Cars</a></li>
				</ul>
			</div>
			<div class="nav-group">
				<h3>Editorial</h3>
				<ul>
					<li><a href="/blog">News & Reviews</a></li>
					<li><a href="/blog/guides">Buying Guides</a></li>
					<li><a href="/blog/maintenance">Maintenance</a></li>
				</ul>
			</div>
			<div class="nav-group">
				<h3>Company</h3>
				<ul>
					<li><a href="/about">About Us</a></li>
					<li><a href="/contact">Contact</a></li>
					<li><a href="/privacy">Privacy Policy</a></li>
				</ul>
			</div>
		</nav>
	</div>
	<div class="footer-bottom">
		&copy; {today.getFullYear()} {SITE_TITLE}. All rights reserved.
		<p class="license">Licensed Dealer #001</p>
	</div>
</footer>

<style>
	footer {
		padding: 4em 1em 2em;
		background: var(--mica-dark);
		color: var(--paper-off);
		border-top: 4px solid var(--accent-color);
	}
	.footer-content {
		max-width: 1200px;
		margin: 0 auto;
		display: grid;
		gap: 3em;
	}
	@media (min-width: 768px) {
		.footer-content {
			grid-template-columns: 1fr 2fr;
		}
	}
	.brand-section h2 {
		color: var(--paper);
		margin-bottom: 0.5em;
	}
	.brand-section p {
		color: var(--metal-gray-light);
		max-width: 30ch;
		line-height: 1.6;
	}
	.footer-nav {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
		gap: 2em;
	}
	.nav-group h3 {
		color: var(--paper);
		font-size: 0.9rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 1.5em;
	}
	.nav-group ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.nav-group li {
		margin-bottom: 0.75em;
	}
	.nav-group a {
		color: var(--metal-gray-light);
		text-decoration: none;
		font-size: 0.95rem;
	}
	.nav-group a:hover {
		color: var(--accent-color);
	}
	.footer-bottom {
		max-width: 1200px;
		margin: 4em auto 0;
		padding-top: 2em;
		border-top: 1px solid var(--black-mica-2);
		text-align: center;
		font-size: 0.85rem;
		color: var(--metal-gray);
	}
	.license {
		margin-top: 0.5em;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}
</style>
