---
import { Image } from 'astro:assets';

interface Props {
	data: {
		make: string;
		model: string;
		engine: string;
		transmission: string;
		fuel: string;
		seats: number;
        image?: any; // Optional property
	};
}

const { data } = Astro.props;
---

<article class="spec-plate">
    {data.image && (
        <div class="image-container">
            <Image src={data.image} alt={data.model} width="300" height="200" />
        </div>
    )}
	<h3>{data.make} {data.model}</h3>
	<ul class="spec-list">
		<li><strong>ENGINE:</strong> {data.engine}</li>
		<li><strong>TRANS:</strong> {data.transmission}</li>
		<li><strong>FUEL:</strong> {data.fuel}</li>
		<li><strong>SEATS:</strong> {data.seats}</li>
	</ul>
</article>
...

<style>
	.spec-plate {
		border: 2px solid var(--text-color);
		padding: 1em; /* Reduced padding */
		background: #FFF;
		border-radius: 0;
        display: flex;
        flex-direction: column;
        height: 100%;
	}
    .image-container {
        margin-bottom: 0.75em;
        overflow: hidden;
    }
    .image-container img {
        width: 100%;
        height: 150px; /* Reduced height */
        object-fit: cover;
    }
	h3 {
		margin: 0 0 0.75em 0;
		font-size: 1.2em; /* Smaller title */
		text-transform: uppercase;
		border-bottom: 2px solid var(--text-color);
		padding-bottom: 0.25em;
        min-height: 2em;
	}
	.spec-list {
		list-style: none;
		padding: 0;
		margin: 0;
        margin-top: auto;
	}
	.spec-list li {
		margin-bottom: 0.25em;
		font-family: monospace;
        font-size: 0.9em; /* Smaller data */
	}
	.spec-list strong {
		color: #666;
		margin-right: 0.25em;
	}
</style>
