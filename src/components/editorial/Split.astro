---
/* Split — an image beside a block of text. side="left" (default) or "right"
   controls which side the image is on. The text is the component's children
   (written as normal markdown inside the tags). Stacks vertically on mobile. */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	image: ImageMetadata | string;
	alt?: string;
	side?: 'left' | 'right';
	caption?: string;
}

const { image, alt = '', side = 'left', caption } = Astro.props;
const isLocal = typeof image !== 'string';
---

<div class={`split split-${side}`}>
	<figure class="split-media">
		{isLocal ? (
			<Image src={image as ImageMetadata} alt={alt} class="split-img" />
		) : (
			<img src={image as string} alt={alt} class="split-img" loading="lazy" decoding="async" />
		)}
		{caption && <figcaption>{caption}</figcaption>}
	</figure>
	<div class="split-body">
		<slot />
	</div>
</div>

<style>
	.split {
		margin: 2.5em 0;
		display: grid;
		gap: 1.5em;
		align-items: center;
	}
	@media (min-width: 720px) {
		.split {
			grid-template-columns: 1fr 1fr;
		}
		.split-right .split-media {
			order: 2;
		}
	}
	.split-media {
		margin: 0;
	}
	.split-img {
		display: block;
		width: 100%;
		height: auto;
		border: 1px solid var(--line);
	}
	.split-media figcaption {
		margin-top: 0.5em;
		font-size: 0.8rem;
		color: var(--metal-gray);
	}
	.split-body :global(p:first-child) {
		margin-top: 0;
	}
	.split-body :global(p:last-child) {
		margin-bottom: 0;
	}
</style>
