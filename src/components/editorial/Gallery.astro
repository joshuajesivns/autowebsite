---
/* Gallery — a responsive grid of images. Pass an array of imported images
   (or string URLs). Optional `alts` and `captions` arrays align by index.
   `cols` overrides the column count (defaults to up to 3). */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	images: (ImageMetadata | string)[];
	alts?: string[];
	captions?: string[];
	cols?: number;
}

const { images = [], alts = [], captions = [], cols } = Astro.props;
const columns = cols ?? Math.min(images.length || 1, 3);
---

<div class="gallery" style={`--cols:${columns}`}>
	{images.map((img, i) => (
		<figure class="g-item">
			{typeof img !== 'string' ? (
				<Image src={img as ImageMetadata} alt={alts[i] ?? ''} class="g-img" />
			) : (
				<img src={img as string} alt={alts[i] ?? ''} class="g-img" loading="lazy" decoding="async" />
			)}
			{captions[i] && <figcaption>{captions[i]}</figcaption>}
		</figure>
	))}
</div>

<style>
	.gallery {
		margin: 2.5em 0;
		display: grid;
		gap: 0.75em;
		grid-template-columns: 1fr;
	}
	@media (min-width: 600px) {
		.gallery {
			grid-template-columns: repeat(var(--cols), 1fr);
		}
	}
	.g-item {
		margin: 0;
	}
	.g-img {
		display: block;
		width: 100%;
		height: 100%;
		aspect-ratio: 4 / 3;
		object-fit: cover;
		border: 1px solid var(--line);
	}
	.g-item figcaption {
		margin-top: 0.4em;
		font-size: 0.78rem;
		color: var(--metal-gray);
	}
</style>
