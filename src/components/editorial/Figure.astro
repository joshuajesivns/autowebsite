---
/* Figure — a single captioned image with controllable width.
   width="column" (default) sits in the reading column;
   width="wide" breaks out modestly beyond the text;
   width="full" spans the full content area (reclaims the TOC sidebar on desktop).
   Pass an imported image (ImageMetadata) for automatic optimization, or a string URL. */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	src: ImageMetadata | string;
	alt?: string;
	caption?: string;
	credit?: string;
	width?: 'column' | 'wide' | 'full';
}

const { src, alt = '', caption, credit, width = 'column' } = Astro.props;
const isLocal = typeof src !== 'string';
---

<figure class={`fig fig-${width}`}>
	{isLocal ? (
		<Image src={src as ImageMetadata} alt={alt} class="fig-img" />
	) : (
		<img src={src as string} alt={alt} class="fig-img" loading="lazy" decoding="async" />
	)}
	{(caption || credit) && (
		<figcaption>
			{caption && <span class="cap">{caption}</span>}
			{credit && <span class="credit">{credit}</span>}
		</figcaption>
	)}
</figure>

<style>
	.fig {
		margin: 2.5em 0;
	}
	.fig-img {
		display: block;
		width: 100%;
		height: auto;
		border: 1px solid var(--line);
	}
	figcaption {
		margin-top: 0.6em;
		padding-left: 0.75em;
		border-left: 3px solid var(--red-mica);
		font-size: 0.85rem;
		color: var(--metal-gray);
		display: flex;
		justify-content: space-between;
		gap: 1em;
		flex-wrap: wrap;
	}
	.credit {
		font-style: italic;
		opacity: 0.8;
		white-space: nowrap;
	}

	/* Breakouts. --bleed-left / --bleed-right are defined on .layout-container
	   in BlogPost.astro so the math tracks the actual sidebar width. */
	.fig-wide {
		margin-inline: clamp(-1.5rem, -6vw, -7rem);
	}
	.fig-full {
		margin-left: calc(-1 * var(--bleed-left, 1.5em));
		margin-right: calc(-1 * var(--bleed-right, 1.5em));
	}
</style>
