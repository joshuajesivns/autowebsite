---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/apex.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE, ORG, SOCIAL_LINKS, GA_MEASUREMENT_ID, GOOGLE_SITE_VERIFICATION, ADSENSE_CLIENT } from '../consts';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	ogType?: 'website' | 'article';
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const site = Astro.site?.href ?? canonicalURL.origin + '/';

const { title, description, image = FallbackImage, ogType = 'website' } = Astro.props;

// Site-wide Organization entity — gives search engines + AI Overviews a single
// authoritative identity (name, logo, NAP, official profiles) to attach trust to.
const addressFields = {
	...(ORG.streetAddress ? { streetAddress: ORG.streetAddress } : {}),
	...(ORG.addressLocality ? { addressLocality: ORG.addressLocality } : {}),
	...(ORG.addressRegion ? { addressRegion: ORG.addressRegion } : {}),
	...(ORG.addressCountry ? { addressCountry: ORG.addressCountry } : {}),
};
// Stable @ids so per-page graphs (e.g. a blog post's BlogPosting) can cross-reference
// these site-wide entities instead of re-declaring them. Base ends in "/" so `${site}#org`
// → "https://www.apexenginehq.com/#org".
const orgId = `${site}#org`;
const webSiteId = `${site}#website`;
const orgSchema = {
	'@type': 'Organization',
	'@id': orgId,
	name: SITE_TITLE,
	url: site,
	logo: new URL('/favicon-512.png', site).href,
	...(ORG.email ? { email: ORG.email } : {}),
	...(ORG.telephone ? { telephone: ORG.telephone } : {}),
	...(Object.keys(addressFields).length ? { address: { '@type': 'PostalAddress', ...addressFields } } : {}),
	...(SOCIAL_LINKS.length ? { sameAs: SOCIAL_LINKS } : {}),
};
const webSiteSchema = {
	'@type': 'WebSite',
	'@id': webSiteId,
	name: SITE_TITLE,
	url: site,
	publisher: { '@id': orgId },
};
// One site-wide @graph carrying both identity entities.
const siteSchema = {
	'@context': 'https://schema.org',
	'@graph': [orgSchema, webSiteSchema],
};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" href="/favicon.ico" sizes="any" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

{GOOGLE_SITE_VERIFICATION && (
	<meta name="google-site-verification" content={GOOGLE_SITE_VERIFICATION} />
)}

<!-- Site-wide identity: Organization + WebSite (cross-linked by @id) -->
<script type="application/ld+json" is:inline set:html={JSON.stringify(siteSchema)} />

<Font cssVariable="--font-atkinson" preload />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.src, Astro.url)} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={Astro.url} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image.src, Astro.url)} />

<!-- Google Analytics 4 — fires ONLY on the live domain, so localhost dev and
     Vercel preview URLs don't inflate Direct traffic in the same property. -->
{GA_MEASUREMENT_ID && (
	<script is:inline set:html={`
		if (location.hostname.endsWith('apexenginehq.com')) {
			var s=document.createElement('script');
			s.async=true;
			s.src='https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}';
			document.head.appendChild(s);
			window.dataLayer=window.dataLayer||[];
			function gtag(){dataLayer.push(arguments);}
			gtag('js',new Date());
			gtag('config','${GA_MEASUREMENT_ID}');
		}
	`} />
)}

<!-- Google AdSense (Auto ads + site verification). Loads only on the live domain,
     same as GA, so previews/localhost don't serve ads. Renders only once
     ADSENSE_CLIENT is set in consts.ts. -->
{ADSENSE_CLIENT && (
	<script is:inline set:html={`
		if (location.hostname.endsWith('apexenginehq.com')) {
			var s=document.createElement('script');
			s.async=true;
			s.src='https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${ADSENSE_CLIENT}';
			s.crossOrigin='anonymous';
			document.head.appendChild(s);
		}
	`} />
)}
