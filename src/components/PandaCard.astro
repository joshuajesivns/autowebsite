---
import { Image } from 'astro:assets';

interface Props {
	title: string;
	description?: string;
	image?: any;
	tags?: string[];
	mileage?: string;
	grade?: string;
	price?: string;
}

const { title, description, image, tags, mileage, grade, price } = Astro.props;
---

<article class="panda-card">
	{image && (
		<div class="card-image-wrapper">
			<Image src={image} alt={title} width={400} height={240} class="card-image" />
		</div>
	)}

	<div class="card-content">
		<h3>{title}</h3>
		
		{description && <p class="card-desc">{description}</p>}

		{(mileage || grade || price) && (
			<div class="spec-plate">
				{mileage && <p><span>KM:</span> <code>{mileage}</code></p>}
				{grade && <p><span>GRADE:</span> <code>{grade}</code></p>}
				{price && <p><span>PHP:</span> <code>{price}</code></p>}
			</div>
		)}

		{tags && tags.length > 0 && (
			<div class="card-tags">
				{tags.map((tag) => (
					<span class="tag-pill">#{tag}</span>
				))}
			</div>
		)}
	</div>
	<slot />
</article>

<style>
	.panda-card {
		border: 1px solid var(--line);
		display: flex;
		flex-direction: column;
		border-radius: 0; /* Engineering Trust: Sharp Edges */
		background: var(--paper);
		transition: border-color 0.15s, box-shadow 0.15s;
		height: 100%;
		overflow: hidden;
	}
	.panda-card:hover {
		border-color: var(--black-mica);
		box-shadow: 0 6px 18px rgba(17, 24, 39, 0.05);
	}

	.card-image-wrapper {
		width: 100%;
		aspect-ratio: 16 / 10;
		overflow: hidden;
		background: var(--paper-off);
		border-bottom: 1px solid var(--line);
	}
	.card-image {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.2s;
	}
	.panda-card:hover .card-image {
		transform: scale(1.02);
	}

	.card-content {
		padding: 1.25em;
		display: flex;
		flex-direction: column;
		gap: 0.75em;
		flex-grow: 1;
	}

	.card-content h3 {
		margin: 0;
		font-size: 1.15rem;
		text-transform: uppercase;
		line-height: 1.2;
		letter-spacing: -0.01em;
	}

	.card-desc {
		font-size: 0.9rem;
		color: var(--metal-gray);
		line-height: 1.5;
		margin: 0;
	}

	.spec-plate {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 0.5em;
		font-family: monospace;
		font-size: 0.8em;
		background: var(--paper-off);
		padding: 0.6em 0.8em;
		border-left: 2px solid var(--accent-color);
	}
	.spec-plate p { margin: 0; }
	.spec-plate span { color: var(--metal-gray); }

	.card-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4em;
		margin-top: auto;
		padding-top: 0.5em;
	}
	.tag-pill {
		font-size: 0.7rem;
		color: var(--metal-gray);
		background: var(--paper-off);
		padding: 0.25em 0.55em;
		font-family: monospace;
		text-transform: uppercase;
	}
</style>
