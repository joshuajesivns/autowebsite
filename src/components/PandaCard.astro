---
interface Props {
	title: string;
	mileage?: string;
	grade?: string;
	price?: string;
}

const { title, mileage, grade, price } = Astro.props;
---

<article class="panda-card">
	<h3>{title}</h3>
    <div class="spec-plate">
        {mileage && <p><span>KM:</span> <code>{mileage}</code></p>}
        {grade && <p><span>GRADE:</span> <code>{grade}</code></p>}
        {price && <p><span>PHP:</span> <code>{price}</code></p>}
    </div>
	<slot />
</article>

<style>
    .panda-card {
        border: 2px solid var(--text-color);
        padding: 1.5em;
        display: flex;
        flex-direction: column;
        gap: 0.5em;
        border-radius: 0; /* Engineering Trust: Sharp Edges */
    }
    .spec-plate {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.5em;
        font-family: monospace;
        font-size: 0.9em;
        background: #F4F4F4;
        padding: 0.75em;
    }
    .spec-plate p { margin: 0; }
    .spec-plate span { color: #666; }
</style>
