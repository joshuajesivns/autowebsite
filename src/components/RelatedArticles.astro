---
interface Props {
	articles: { title: string; url: string }[];
}

const { articles } = Astro.props;
---

<aside class="related-articles">
	<h4>Related Articles</h4>
	<ul>
		{articles.map((art) => <li><a href={art.url}>{art.title}</a></li>)}
	</ul>
</aside>

<style>
	.related-articles {
		border: 1px solid var(--text-color);
		padding: 1em;
		margin-top: 2em;
	}
</style>
