---
export const prerender = false;
import Layout from '../../layouts/Page.astro';

const error = Astro.url.searchParams.get('error');
---

<Layout title="Moderator Login" description="Apex Engine internal moderation login.">
	{error && <p class="error-message">Incorrect password.</p>}
	<form method="POST" action="/api/admin/login" class="login-form">
		<div class="form-group">
			<label for="password">Password</label>
			<input type="password" id="password" name="password" required autofocus />
		</div>
		<button type="submit" class="primary">Log In</button>
	</form>
</Layout>

<style>
	.login-form {
		display: flex;
		flex-direction: column;
		gap: 1.25em;
		margin-top: 1.5em;
		max-width: 320px;
	}
	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.4em;
	}
	label {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	input {
		padding: 0.75em;
		border: 1px solid var(--metal-gray-light);
		background: var(--paper);
		font-family: inherit;
		font-size: 0.95rem;
	}
	input:focus-visible {
		outline: 2px solid var(--accent-color);
	}
	.error-message {
		color: var(--red-mica-dark, #B91C1C);
		font-weight: 700;
	}
</style>
