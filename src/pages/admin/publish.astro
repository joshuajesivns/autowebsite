	.prose-preview .prev-pq { font-size: 1.4rem; font-style: italic; border-left: 4px solid var(--red-mica); color: var(--black-mica-2); }
	.prev-fig { margin: 1.5em 0; }
	.prev-fig-ph { background: var(--paper-off); border: 1px dashed var(--metal-gray-light); color: var(--metal-gray); padding: 2em; text-align: center; font-size: 0.9rem; }
	.prev-fig figcaption { margin-top: 0.5em; padding-left: 0.75em; border-left: 3px solid var(--red-mica); font-size: 0.85rem; color: var(--metal-gray); }

	/* structured schema fields */
	#schemaFields { margin-top: 1.5em; }
	.sf-panel { border: 1px solid var(--line); border-radius: 6px; background: var(--paper); margin-bottom: 0.6em; }
	.sf-panel summary { cursor: pointer; display: flex; justify-content: space-between; align-items: center; padding: 0.7em 1em; font-weight: 700; }
