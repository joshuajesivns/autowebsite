---
export const prerender = false;

import PageLayout from '../../layouts/Page.astro';
import { ADMIN_COOKIE_NAME, isValidAdminSession } from '../../lib/adminAuth';

if (!isValidAdminSession(Astro.cookies.get(ADMIN_COOKIE_NAME)?.value)) {
	return Astro.redirect('/admin/login');
}
---

<PageLayout title="Publish a Post" description="Paste an AI-written MDX article, review its SEO/schema/links, and publish it to Apex Engine.">
	<p class="lede">
		Paste the finished MDX, click <strong>Analyze</strong> for the Google preview + checks (content, images/alt,
		schema, internal links), add schema fields + alt text + photos, then <strong>Publish</strong>. A bad paste can't
		break the live site — a failed build just keeps the last good version.
	</p>

	<div id="editBanner" class="edit-banner" hidden>
		<span><strong>Editing <code id="editSlugLabel"></code></strong> — publishing overwrites the live post.</span>
		<button id="exitEditBtn" type="button" class="link-btn">Start a new post instead</button>
	</div>

	<div class="draft-note" id="draftNote" hidden>
		<span>Restored an unsaved draft from this browser.</span>
		<button id="clearDraftBtn" type="button" class="link-btn">Clear it</button>
	</div>

	<label class="field-label" for="mdx">Article MDX</label>
	<textarea id="mdx" placeholder="Paste the full MDX (--- frontmatter --- then the body)…" spellcheck="false"></textarea>

	<div class="row">
		<button id="scanBtn" type="button" class="primary">Analyze</button>
		<span class="muted kbd-hint">or press <kbd>Ctrl</kbd>/<kbd>⌘</kbd>+<kbd>Enter</kbd></span>
		<span id="scanMsg" class="muted"></span>
	</div>

	<section id="report" hidden>
		<div id="errors"></div>

		<!-- Google snippet preview (Yoast-style) -->
		<div id="serp" class="serp" hidden>
			<div class="serp-title" id="serpTitle"></div>
			<div class="serp-url" id="serpUrl"></div>
			<div class="serp-desc" id="serpDesc"></div>
		</div>
		<div id="bars" class="bars" hidden></div>

		<!-- Rendered article preview -->
		<details id="previewPanel" class="panel prev-panel" hidden>
			<summary><span class="panel-title">Article preview</span><span class="panel-badge muted">approx. rendering</span></summary>
			<div class="panel-body"><div id="previewBody" class="prose-preview"></div></div>
		</details>

		<!-- Traffic-light analysis -->
		<div id="panels" class="panels" hidden></div>

		<div class="field-group" id="slugGroup" hidden>
			<label class="field-label" for="slug">Slug (the URL: /blog/<span id="slugEcho">…</span>/)</label>
			<input type="text" id="slug" />
			<div id="slugWarn" class="warn-row" hidden>
				<span id="slugWarnText" class="warn"></span>
				<button id="editBtn" type="button" class="link-btn">Load &amp; edit that post →</button>
			</div>
		</div>

		<!-- Structured schema fields (vehicle / pms / featuredProducts), built per vertical -->
		<section id="schemaFields" hidden>
			<h2 class="section-h">Schema fields</h2>
			<p class="muted">These feed the post's JSON-LD (Vehicle / HowTo / Product). Pre-filled from your MDX if present. Leave a section blank to skip it; fill it to enrich the schema — no need to hand-write YAML.</p>
			<div id="sfPanels"></div>
		</section>

		<div id="slotsWrap" hidden>
			<h2 class="section-h">Images &amp; alt text</h2>
			<p class="muted">Write alt text for every image (accessibility + image SEO). Attach a photo to replace a placeholder, or leave blank to keep it. Photos are auto-resized and converted to WebP before upload.</p>
			<div id="slots"></div>
		</div>

		<div class="row publish-row">
			<button id="publishBtn" type="button" class="primary" disabled>Publish</button>
			<span id="publishMsg" class="muted"></span>
		</div>
	</section>

	<div id="done" class="done-box" hidden></div>
</PageLayout>

<script>
	const $ = (id) => document.getElementById(id);
	let scanned = null; // { slots }
	let editMode = null; // slug string when editing an existing post
	const DRAFT_KEY = 'apex-publish-draft';

	function esc(s) {
		return String(s ?? '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));
	}
	const DOT = { good: '🟢', warn: '🟠', bad: '🔴' };

	async function api(body) {
		const res = await fetch('/api/admin/publish', {
			method: 'POST',
			headers: { 'Content-Type': 'application/json' },
			body: JSON.stringify(body),
		});
		return res.json();
	}

	async function fileToWebpBase64(file, maxDim = 2000, quality = 0.85) {
		const bitmap = await createImageBitmap(file);
		const scale = Math.min(1, maxDim / Math.max(bitmap.width, bitmap.height));
		const w = Math.round(bitmap.width * scale);
		const h = Math.round(bitmap.height * scale);
		const canvas = document.createElement('canvas');
		canvas.width = w;
		canvas.height = h;
		canvas.getContext('2d').drawImage(bitmap, 0, 0, w, h);
		const blob = await new Promise((r) => canvas.toBlob(r, 'image/webp', quality));
		const buf = new Uint8Array(await blob.arrayBuffer());
		let bin = '';
		for (let i = 0; i < buf.length; i++) bin += String.fromCharCode(buf[i]);
		return btoa(bin);
	}

	function checkList(checks) {
		if (!checks || !checks.length) return '';
		return '<ul class="checks">' + checks.map((c) => `<li class="lv-${c.level}"><span class="dot">${DOT[c.level]}</span>${esc(c.text)}</li>`).join('') + '</ul>';
	}
	function tally(checks) {
		const c = { good: 0, warn: 0, bad: 0 };
		(checks || []).forEach((x) => c[x.level]++);
		const parts = [];
		if (c.good) parts.push(`🟢 ${c.good}`);
		if (c.warn) parts.push(`🟠 ${c.warn}`);
		if (c.bad) parts.push(`🔴 ${c.bad}`);
		return parts.join('  ');
	}

	function renderBar(label, len, state, hint) {
		return `<div class="bar-row">
			<span class="bar-label">${label}</span>
			<span class="bar-track"><span class="bar-fill lv-${state}" style="width:${Math.min(100, len)}%"></span></span>
			<span class="bar-num lv-${state}">${len} ${DOT[state]}</span>
			<span class="bar-hint">${hint}</span>
		</div>`;
	}

	function renderPreview(pv) {
		$('serp').hidden = false;
		$('bars').hidden = false;
		$('serpTitle').textContent = pv.titleFull || '(no title)';
		$('serpUrl').textContent = pv.url;
		$('serpDesc').textContent = pv.description || '(no description)';
		$('bars').innerHTML =
			renderBar('SEO title', pv.titleLen, pv.titleState, 'aim 55–58') +
			renderBar('Meta desc', pv.descLen, pv.descState, 'aim 155–158') +
			`<div class="bar-row"><span class="bar-label">"Apex Engine"</span><span class="bar-note lv-${pv.apexState}">${DOT[pv.apexState]} appears ${pv.apexCount}× (want 1)</span></div>`;
	}

	function renderPanels(a) {
		const linkChecks = a.links.checks.slice();
		let linksExtra = '';
		if (a.links.targets.length) linksExtra += '<div class="sub">Linked: ' + a.links.targets.map((t) => `<code>${esc(t)}</code>`).join(' ') + '</div>';
		if (a.links.suggestions.length) {
			linksExtra += '<div class="sub">Consider linking:<ul class="sugg">' +
				a.links.suggestions.map((s) => `<li><code>/blog/${esc(s.slug)}/</code> — ${esc(s.title)} <span class="tag">${esc(s.vertical)}</span></li>`).join('') +
				'</ul></div>';
		}
		const schemaPills = a.schema.nodes.map((n) => `<span class="pill lv-${n.level}">${DOT[n.level]} ${esc(n.label)}</span>`).join('');

		$('panels').hidden = false;
		$('panels').innerHTML = [
			panel('Content', tally(a.content), checkList(a.content)),
			panel('Images & alt', tally(a.images), checkList(a.images)),
			panel('Schema', '', `<div class="pills">${schemaPills}</div>${checkList(a.schema.notes)}`),
			panel('Internal linking', tally(linkChecks), checkList(linkChecks) + linksExtra),
		].join('');
	}
	function panel(title, badge, inner) {
		return `<details class="panel" open>
			<summary><span class="panel-title">${title}</span><span class="panel-badge">${badge}</span></summary>
			<div class="panel-body">${inner}</div>
		</details>`;
	}

	// ── Approximate MDX → HTML preview (client-side, no dependency) ─────────────
	function inlineMd(s) {
		s = esc(s);
		s = s.replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
		s = s.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
		s = s.replace(/(^|[^*])\*([^*]+)\*/g, '$1<em>$2</em>');
		s = s.replace(/`([^`]+)`/g, '<code>$1</code>');
		return s;
	}

	function mdToHtml(body) {
		body = body
			.replace(/^import\s.+$/gm, '')
			.replace(/\{\/\*[\s\S]*?\*\/\}/g, '')
			.replace(/<Pullquote>([\s\S]*?)<\/Pullquote>/g, (_, t) => `\n\n§PQ§${t.trim()}§PQ§\n\n`)
			.replace(/<Figure\b[^>]*?caption=["']([^"']*)["'][^>]*?\/>/g, (_, c) => `\n\n§FIG§${c}§FIG§\n\n`)
			.replace(/<Figure\b[^>]*?\/>/g, '\n\n§FIG§§FIG§\n\n')
			.replace(/<\/?Split\b[^>]*>/g, '')
			.replace(/<\/?Gallery\b[^>]*>/g, '')
			.replace(/<[^>\n]+\/>/g, '');

		const lines = body.split('\n');
		const out = [];
		let i = 0;
		const flushPara = (buf) => { if (buf.length) out.push('<p>' + inlineMd(buf.join(' ')) + '</p>'); };
		let para = [];

		while (i < lines.length) {
			let line = lines[i];
			const raw = line.trimEnd();

			if (!raw.trim()) { flushPara(para); para = []; i++; continue; }

			let mk = raw.match(/^§PQ§([\s\S]*)§PQ§$/);
			if (mk) { flushPara(para); para = []; out.push(`<blockquote class="prev-pq">${inlineMd(mk[1])}</blockquote>`); i++; continue; }
			mk = raw.match(/^§FIG§(.*)§FIG§$/);
			if (mk) { flushPara(para); para = []; out.push(`<figure class="prev-fig"><div class="prev-fig-ph">🖼 image</div>${mk[1] ? `<figcaption>${esc(mk[1])}</figcaption>` : ''}</figure>`); i++; continue; }

			mk = raw.match(/^(#{1,6})\s+(.*)$/);
			if (mk) { flushPara(para); para = []; const lvl = Math.min(mk[1].length, 6); out.push(`<h${lvl}>${inlineMd(mk[2])}</h${lvl}>`); i++; continue; }

			if (/^(-{3,}|\*{3,})$/.test(raw.trim())) { flushPara(para); para = []; out.push('<hr />'); i++; continue; }

			if (/^\s*\|/.test(raw) && i + 1 < lines.length && /^\s*\|?\s*:?-{2,}/.test(lines[i + 1])) {
				flushPara(para); para = [];
				const cells = (r) => r.trim().replace(/^\||\|$/g, '').split('|').map((c) => c.trim());
				const head = cells(raw);
				i += 2;
				const rows = [];
				while (i < lines.length && /^\s*\|/.test(lines[i])) { rows.push(cells(lines[i])); i++; }
				let t = '<table><thead><tr>' + head.map((c) => `<th>${inlineMd(c)}</th>`).join('') + '</tr></thead><tbody>';
				t += rows.map((r) => '<tr>' + r.map((c) => `<td>${inlineMd(c)}</td>`).join('') + '</tr>').join('');
				t += '</tbody></table>';
				out.push(t);
				continue;
			}

			if (/^\s*[-*]\s+/.test(raw)) {
				flushPara(para); para = [];
				const items = [];
				while (i < lines.length && /^\s*[-*]\s+/.test(lines[i])) { items.push(lines[i].replace(/^\s*[-*]\s+/, '')); i++; }
				out.push('<ul>' + items.map((it) => `<li>${inlineMd(it)}</li>`).join('') + '</ul>');
				continue;
			}
			if (/^\s*\d+\.\s+/.test(raw)) {
				flushPara(para); para = [];
				const items = [];
				while (i < lines.length && /^\s*\d+\.\s+/.test(lines[i])) { items.push(lines[i].replace(/^\s*\d+\.\s+/, '')); i++; }
				out.push('<ol>' + items.map((it) => `<li>${inlineMd(it)}</li>`).join('') + '</ol>');
				continue;
			}
			if (/^\s*>\s?/.test(raw)) {
				flushPara(para); para = [];
				const q = [];
				while (i < lines.length && /^\s*>\s?/.test(lines[i])) { q.push(lines[i].replace(/^\s*>\s?/, '')); i++; }
				out.push(`<blockquote>${inlineMd(q.join(' '))}</blockquote>`);
				continue;
			}

			para.push(raw.trim());
			i++;
		}
		flushPara(para);
		return out.join('\n');
	}

	function renderArticlePreview(mdx) {
		const m = mdx.replace(/^﻿/, '').replace(/\r\n/g, '\n').match(/^---\n[\s\S]*?\n---\n?([\s\S]*)$/);
		const body = m ? m[1] : mdx;
		$('previewPanel').hidden = false;
		$('previewBody').innerHTML = mdToHtml(body) || '<p class="muted">Nothing to preview yet.</p>';
	}

	// ── Structured schema fields ────────────────────────────────────────────────
	function field(label, id, value, ph = '', type = 'text') {
		return `<label class="sf-field"><span>${label}</span><input type="${type}" id="${id}" value="${esc(value ?? '')}" placeholder="${esc(ph)}" /></label>`;
	}
	function engineRow(e = {}) {
		return `<div class="eng-row sf-repeat-row">
			<input class="eng-name" placeholder="Engine name*, e.g. 4A-GE (NA)" value="${esc(e.name || '')}" />
			<input class="eng-type" placeholder="Type, e.g. 1.6L DOHC NA" value="${esc(e.engineType || '')}" />
			<input class="eng-power" placeholder="Power, e.g. 120–140" value="${esc(e.power || '')}" />
			<input class="eng-unit" placeholder="Unit (PS)" value="${esc(e.powerUnit || '')}" />
			<button type="button" class="row-del" title="Remove">✕</button>
		</div>`;
	}
	function stepRow(prefix, s = '') {
		return `<div class="step-row sf-repeat-row"><input placeholder="Service step, e.g. Engine oil + filter" value="${esc(s)}" /><button type="button" class="row-del" title="Remove">✕</button></div>`;
	}
	function prodRow(p = {}) {
		return `<div class="prod-row sf-repeat-row prod">
			<input class="prod-name" placeholder="Product name*" value="${esc(p.name || '')}" />
			<input class="prod-cat" placeholder="Category" value="${esc(p.category || '')}" />
			<input class="prod-brand" placeholder="Brand" value="${esc(p.brand || '')}" />
			<input class="prod-url" placeholder="Affiliate URL*" value="${esc(p.url || '')}" />
			<input class="prod-desc" placeholder="Your take / why it fits" value="${esc(p.description || '')}" />
			<button type="button" class="row-del" title="Remove">✕</button>
		</div>`;
	}
	function pmsServicePanel(key, title, svc) {
		svc = svc || {};
		const steps = (svc.steps || []).map((s) => stepRow(key, s)).join('') || stepRow(key);
		return `<fieldset class="sf-sub"><legend>${title}</legend>
			<div class="sf-grid">
				${field('Name', `${key}-name`, svc.name, key === 'light' ? 'Light (Minor) PMS' : 'Heavy (Major) PMS')}
				${field('Interval', `${key}-interval`, svc.interval, 'e.g. 10,000 km / 6 months')}
				${field('Cost min (₱)', `${key}-min`, svc.costMin, 'e.g. 1500', 'number')}
				${field('Cost max (₱)', `${key}-max`, svc.costMax, 'e.g. 2500', 'number')}
			</div>
			<div class="sf-repeat" id="${key}-steps" data-add="step" data-key="${key}">
				<span class="sf-repeat-label">Steps</span>${steps}
				<button type="button" class="add-row" data-add="step" data-key="${key}">+ Add step</button>
			</div>
		</fieldset>`;
	}

	function renderSchemaFields(recipe, s) {
		const wrap = $('schemaFields');
		if (!recipe || !(recipe.vehicle || recipe.howto || recipe.products)) {
			wrap.hidden = true;
			$('sfPanels').innerHTML = '';
			return;
		}
		wrap.hidden = false;
		const parts = [];

		if (recipe.vehicle) {
			const v = s?.vehicle || {};
			const drives = ['', 'FWD', 'RWD', 'AWD', '4WD'];
			const engines = (v.engines || []).map(engineRow).join('') || engineRow();
			parts.push(`<details class="sf-panel" id="vehPanel" ${v.name ? 'open' : ''}>
				<summary><span class="panel-title">Vehicle</span><span class="panel-badge muted">${v.name ? 'present' : 'optional'}</span></summary>
				<div class="panel-body">
					<div class="sf-grid">
						${field('Display name*', 'veh-name', v.name, 'e.g. Toyota Corolla AE92 (Levin / Trueno)')}
						${field('Brand', 'veh-brand', v.brand, 'e.g. Toyota')}
						${field('Model', 'veh-model', v.model, 'e.g. Corolla AE92')}
						${field('Model years', 'veh-date', v.vehicleModelDate, 'e.g. 1987/1991')}
						${field('Body type', 'veh-body', v.bodyType, 'e.g. Coupe')}
						${field('Fuel type', 'veh-fuel', v.fuelType, 'e.g. Gasoline')}
						${field('Transmission', 'veh-trans', v.transmission, 'e.g. 5-speed manual')}
						<label class="sf-field"><span>Drivetrain</span><select id="veh-drive">${drives.map((d) => `<option value="${d}" ${v.drivetrain === d ? 'selected' : ''}>${d || '—'}</option>`).join('')}</select></label>
					</div>
					<div class="sf-repeat" id="veh-engines" data-add="engine">
						<span class="sf-repeat-label">Engines</span>${engines}
						<button type="button" class="add-row" data-add="engine">+ Add engine</button>
					</div>
				</div>
			</details>`);
		}

		if (recipe.howto) {
			const p = s?.pms || {};
			const on = (p.light || p.heavy);
			parts.push(`<details class="sf-panel" id="pmsPanel" ${on ? 'open' : ''}>
				<summary><span class="panel-title">PMS servicing</span><span class="panel-badge muted">${on ? 'present' : 'optional'}</span></summary>
				<div class="panel-body">
					${field('Currency', 'pms-currency', p.currency || 'PHP', 'PHP')}
					${pmsServicePanel('light', 'Light (Minor) PMS', p.light)}
					${pmsServicePanel('heavy', 'Heavy (Major) PMS', p.heavy)}
				</div>
			</details>`);
		}

		if (recipe.products) {
			const list = (s?.featuredProducts || []);
			const rows = list.map(prodRow).join('') || prodRow();
			parts.push(`<details class="sf-panel" id="prodPanel" ${list.length ? 'open' : ''}>
				<summary><span class="panel-title">Recommended products</span><span class="panel-badge muted">${list.length ? `${list.length}` : 'optional'}</span></summary>
				<div class="panel-body">
					<p class="muted sf-hint">Only add products the post actually shows — this renders a visible "Recommended parts" block <em>and</em> the Product schema from the same data. No prices (they go stale).</p>
					<div class="sf-repeat" id="prod-list" data-add="prod">
						${rows}
						<button type="button" class="add-row" data-add="prod">+ Add product</button>
					</div>
				</div>
			</details>`);
		}

		$('sfPanels').innerHTML = parts.join('');
	}

	// Add/remove repeater rows via delegation.
	document.addEventListener('click', (e) => {
		const add = e.target.closest('.add-row');
		if (add) {
			const kind = add.dataset.add;
			let html = '';
			if (kind === 'engine') html = engineRow();
			else if (kind === 'prod') html = prodRow();
			else if (kind === 'step') html = stepRow(add.dataset.key);
			add.insertAdjacentHTML('beforebegin', html);
			return;
		}
		const del = e.target.closest('.row-del');
		if (del) { del.closest('.sf-repeat-row')?.remove(); }
	});

	function val(sel, root = document) { const el = root.querySelector(sel); return el ? el.value.trim() : ''; }
	function numOr(v) { const n = Number(v); return v !== '' && Number.isFinite(n) ? n : undefined; }

	// Read the schema forms back into a { vehicle?, pms?, featuredProducts? } payload.
	// Only sections whose panel is rendered are included — so a vertical that doesn't
	// show a panel (e.g. news) never touches that block. A rendered-but-empty section
	// sends null → removes the block (deliberate; the form was pre-filled if data existed).
	function collectStructured() {
		const out = {};
		if ($('schemaFields').hidden) return out;

		if ($('vehPanel')) {
			const engines = [...document.querySelectorAll('#veh-engines .eng-row')]
				.map((r) => ({ name: val('.eng-name', r), engineType: val('.eng-type', r), power: val('.eng-power', r), powerUnit: val('.eng-unit', r) }))
				.filter((x) => x.name);
			const name = val('#veh-name');
			out.vehicle = name
				? {
						name,
						brand: val('#veh-brand'),
						model: val('#veh-model'),
						vehicleModelDate: val('#veh-date') || undefined,
						bodyType: val('#veh-body') || undefined,
						fuelType: val('#veh-fuel') || undefined,
						transmission: val('#veh-trans') || undefined,
						drivetrain: val('#veh-drive') || undefined,
						engines: engines.length ? engines : undefined,
					}
				: null;
		}

		if ($('pmsPanel')) {
			const svc = (key) => {
				const steps = [...document.querySelectorAll(`#${key}-steps .step-row input`)].map((i) => i.value.trim()).filter(Boolean);
				const name = val(`#${key}-name`), interval = val(`#${key}-interval`), min = val(`#${key}-min`), max = val(`#${key}-max`);
				if (!name && !interval && !min && !max && !steps.length) return undefined;
				return { name: name || undefined, interval: interval || undefined, costMin: numOr(min), costMax: numOr(max), steps: steps.length ? steps : undefined };
			};
			const light = svc('light'), heavy = svc('heavy');
			out.pms = light || heavy ? { currency: val('#pms-currency') || 'PHP', light, heavy } : null;
		}

		if ($('prodPanel')) {
			const list = [...document.querySelectorAll('#prod-list .prod-row')]
				.map((r) => ({ name: val('.prod-name', r), category: val('.prod-cat', r), brand: val('.prod-brand', r), description: val('.prod-desc', r), url: val('.prod-url', r) }))
				.filter((x) => x.name && x.url);
			out.featuredProducts = list.length ? list : null;
		}
		return out;
	}

	// ── Scan / Analyze ──────────────────────────────────────────────────────────
	async function scan() {
		const mdx = $('mdx').value;
		$('scanMsg').textContent = 'Analyzing…';
		$('publishBtn').disabled = true;
		$('done').hidden = true;
		let r;
		try {
			r = await api({ action: 'scan', mdx, editSlug: editMode || '' });
		} catch (e) {
			$('scanMsg').textContent = 'Analyze failed: ' + e.message;
			return;
		}
		$('scanMsg').textContent = '';
		$('report').hidden = false;

		if (r.errors && r.errors.length) {
			$('errors').innerHTML =
				'<div class="err-box"><strong>Fix these before publishing:</strong><ul>' +
				r.errors.map((e) => `<li>${esc(e)}</li>`).join('') + '</ul></div>';
		} else {
			$('errors').innerHTML = '<div class="ok-box">✓ Frontmatter valid — ready to publish (address any 🟠 below to sharpen it).</div>';
		}

		if (r.preview) renderPreview(r.preview);
		if (r.analysis) renderPanels(r.analysis);
		renderArticlePreview($('mdx').value);
		renderSchemaFields(r.recipe, r.structured);

		// slug
		$('slugGroup').hidden = false;
		$('slug').value = r.slug || '';
		$('slug').readOnly = !!editMode;
		$('slugEcho').textContent = r.slug || '…';
		$('slugWarn').hidden = !r.slugTaken;
		if (r.slugTaken) $('slugWarnText').textContent = `⚠ A post "${r.slug}" already exists.`;

		// slots (with alt fields)
		const slots = r.slots || [];
		$('slotsWrap').hidden = slots.length === 0;
		$('slots').innerHTML = slots
			.map(
				(s) => `
			<div class="slot" data-id="${esc(s.id)}" data-kind="${esc(s.kind)}">
				<div class="slot-head">
					<span class="slot-id">${s.kind === 'hero' ? 'HERO' : esc(s.id)}</span>
					<span class="slot-cap">${esc(s.caption || '')}</span>
					${s.isPlaceholder ? '<span class="slot-ph">placeholder</span>' : ''}
				</div>
				<input type="text" class="slot-alt ${s.alt ? '' : 'needs-alt'}" placeholder="Alt text (describe the image)…" value="${esc(s.alt || '')}" />
				<div class="slot-file-row">
					<input type="file" accept="image/*" class="slot-file" />
					<img class="slot-thumb" hidden alt="" />
				</div>
			</div>`,
			)
			.join('');

		document.querySelectorAll('.slot-file').forEach((inp) => {
			inp.addEventListener('change', (e) => {
				const file = e.target.files[0];
				const thumb = e.target.parentElement.querySelector('.slot-thumb');
				if (file) { thumb.src = URL.createObjectURL(file); thumb.hidden = false; }
				else thumb.hidden = true;
			});
		});
		document.querySelectorAll('.slot-alt').forEach((inp) => {
			inp.addEventListener('input', (e) => e.target.classList.toggle('needs-alt', !e.target.value.trim()));
		});

		scanned = { slots };
		$('slug').oninput = () => ($('slugEcho').textContent = $('slug').value || '…');
		// Publish blocked only on hard errors / slug clash — 🟠 warnings are advisory.
		$('publishBtn').disabled = (r.errors && r.errors.length > 0) || !!r.slugTaken;
		$('publishBtn').textContent = editMode ? 'Update post' : 'Publish';
	}

	// ── Edit mode ─────────────────────────────────────────────────────────────
	async function loadForEdit(slugArg) {
		const slug = (slugArg || $('slug').value).trim();
		if (!slug) return;
		$('scanMsg').textContent = `Loading "${slug}"…`;
		let r;
		try { r = await api({ action: 'load', slug }); } catch (e) { $('scanMsg').textContent = 'Load failed: ' + e.message; return; }
		if (!r.ok) { $('scanMsg').textContent = r.error || 'Load failed.'; return; }
		editMode = r.slug;
		$('mdx').value = r.mdx;
		$('editSlugLabel').textContent = r.slug;
		$('editBanner').hidden = false;
		saveDraft();
		await scan();
	}
	function exitEdit() {
		editMode = null;
		$('editBanner').hidden = true;
		$('slug').readOnly = false;
		$('publishBtn').textContent = 'Publish';
	}

	// ── Publish ───────────────────────────────────────────────────────────────
	async function publish() {
		if (!scanned) return;
		const btn = $('publishBtn');
		btn.disabled = true;
		const msg = $('publishMsg');
		const uploads = { body: {} };
		const alts = { body: {} };

		try {
			const slotEls = [...document.querySelectorAll('.slot')];
			for (const el of slotEls) {
				const id = el.dataset.id;
				const kind = el.dataset.kind;
				const altVal = el.querySelector('.slot-alt').value.trim();
				if (altVal) { if (kind === 'hero') alts.hero = altVal; else alts.body[id] = altVal; }

				const file = el.querySelector('.slot-file').files[0];
				if (!file) continue;
				msg.textContent = `Uploading ${kind === 'hero' ? 'hero' : id}…`;
				const dataBase64 = await fileToWebpBase64(file);
				const up = await api({ action: 'upload-blob', filename: id + '.webp', dataBase64 });
				if (!up.ok) throw new Error(up.error || 'upload failed');
				if (kind === 'hero') uploads.hero = { sha: up.sha, ext: up.ext };
				else uploads.body[id] = { sha: up.sha, ext: up.ext };
			}

			const structured = collectStructured();
			msg.textContent = editMode ? 'Updating…' : 'Publishing…';
			const r = await api({ action: 'publish', mdx: $('mdx').value, slug: $('slug').value, uploads, alts, structured, edit: !!editMode });
			if (!r.ok) throw new Error((r.errors && r.errors.join('; ')) || r.error || 'publish failed');

			msg.textContent = '';
			clearDraft();
			$('done').hidden = false;
			$('done').innerHTML =
				`<strong>✓ ${r.edited ? 'Updated' : 'Published'}.</strong> Vercel is now building — your post will be live at ` +
				`<a href="${esc(r.url)}" target="_blank" rel="noopener">${esc(r.url)}</a> in a minute or two.`;
		} catch (e) {
			msg.textContent = 'Error: ' + e.message;
			btn.disabled = false;
		}
	}

	// ── Draft autosave (localStorage) ───────────────────────────────────────────
	let saveTimer = null;
	function saveDraft() {
		try { localStorage.setItem(DRAFT_KEY, JSON.stringify({ mdx: $('mdx').value, editMode })); } catch {}
	}
	function clearDraft() { try { localStorage.removeItem(DRAFT_KEY); } catch {} $('draftNote').hidden = true; }
	function restoreDraft() {
		let d;
		try { d = JSON.parse(localStorage.getItem(DRAFT_KEY) || 'null'); } catch { d = null; }
		if (d && d.mdx && !$('mdx').value) {
			$('mdx').value = d.mdx;
			if (d.editMode) { editMode = d.editMode; $('editSlugLabel').textContent = d.editMode; $('editBanner').hidden = false; }
			$('draftNote').hidden = false;
		}
	}

	$('mdx').addEventListener('input', () => { clearTimeout(saveTimer); saveTimer = setTimeout(saveDraft, 600); });
	$('mdx').addEventListener('keydown', (e) => {
		if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') { e.preventDefault(); scan(); }
	});
	$('scanBtn').addEventListener('click', scan);
	$('publishBtn').addEventListener('click', publish);
	$('editBtn').addEventListener('click', () => loadForEdit());
	$('exitEditBtn').addEventListener('click', exitEdit);
	$('clearDraftBtn').addEventListener('click', () => { $('mdx').value = ''; exitEdit(); clearDraft(); });

	// Deep-link: /admin/publish/?edit=<slug> (from the Posts list) loads that post
	// straight into edit mode. Otherwise fall back to restoring any autosaved draft.
	const editParam = new URLSearchParams(location.search).get('edit');
	if (editParam) loadForEdit(editParam);
	else restoreDraft();
</script>

