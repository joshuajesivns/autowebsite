	.prose-preview table { width: 100%; border-collapse: collapse; margin: 1.5em 0; font-size: 0.9rem; }
	.prose-preview th { background: var(--text-color); color: var(--bg-color); padding: 0.5em 0.6em; text-align: left; }
	.prose-preview td { border: 1px solid var(--line); padding: 0.5em 0.6em; }
