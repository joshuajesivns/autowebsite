---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import VehicleSpecCard from '../components/VehicleSpecCard.astro';
import PandaCard from '../components/PandaCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import heroImage from '../assets/hero-hero.jpg';
import '../styles/apex.css';

// Mock data — shape matches the future listing-card contract in VehicleSpecCard.
const featuredListings = [
    { make: "Toyota", model: "AE86 Trueno", year: 1985, engine: "4A-GE", transmission: "MT", fuel: "Gasoline", seats: 4, mileage: "118,400 km", grade: "4 / B", price: 1450000, verified: true, image: heroImage },
    { make: "Nissan", model: "Skyline GT-R", year: 1999, engine: "RB26DETT", transmission: "MT", fuel: "Gasoline", seats: 4, mileage: "86,200 km", grade: "4.5 / A", price: 4200000, verified: true, image: heroImage },
    { make: "Mitsubishi", model: "Lancer Evo VI", year: 1999, engine: "4G63", transmission: "MT", fuel: "Gasoline", seats: 5, mileage: "102,750 km", grade: "4 / B", price: 1850000, verified: true, image: heroImage },
    { make: "Honda", model: "NSX Type-R", year: 1995, engine: "C32B", transmission: "MT", fuel: "Gasoline", seats: 2, mileage: "64,900 km", grade: "5 / A", price: 6800000, verified: true, image: heroImage },
    { make: "Toyota", model: "Supra A80", year: 1997, engine: "2JZ-GTE", transmission: "MT", fuel: "Gasoline", seats: 4, mileage: "94,300 km", grade: "4.5 / B", price: 3950000, verified: true, image: heroImage },
    { make: "Subaru", model: "Impreza WRX STI", year: 2000, engine: "EJ20", transmission: "MT", fuel: "Gasoline", seats: 5, mileage: "121,000 km", grade: "4 / C", price: 1320000, verified: true, image: heroImage },
    { make: "Mazda", model: "RX-7 FD", year: 1996, engine: "13B-REW", transmission: "MT", fuel: "Gasoline", seats: 2, mileage: "78,500 km", grade: "4.5 / B", price: 2600000, verified: true, image: heroImage },
    { make: "Toyota", model: "Celica GT-Four", year: 1994, engine: "3S-GTE", transmission: "MT", fuel: "Gasoline", seats: 4, mileage: "133,200 km", grade: "4 / B", price: 980000, verified: true, image: heroImage },
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section id="hero">
				<Image
					class="hero-bg"
					src={heroImage}
					alt=""
					widths={[768, 1280, 1920]}
					sizes="100vw"
					loading="eager"
					fetchpriority="high"
					aria-hidden="true"
				/>
				<div class="hero-overlay">
                    <h1>The Apex of Automotive Engineering</h1>
                    <p class="hero-sub">Verified imports and honest technical documentation — every machine, fully spec'd.</p>
                    <form class="quick-search" action="/listings" method="get">
                        <div class="field">
                            <label class="sr-only" for="search-make">Make</label>
                            <select id="search-make" name="make">
                                <option value="">Make</option>
                                <option value="toyota">Toyota</option>
                                <option value="nissan">Nissan</option>
                                <option value="honda">Honda</option>
                                <option value="mazda">Mazda</option>
                            </select>
                        </div>
                        <div class="field">
                            <label class="sr-only" for="search-model">Model</label>
                            <select id="search-model" name="model">
                                <option value="">Model</option>
                            </select>
                        </div>
                        <div class="field">
                            <label class="sr-only" for="search-budget">Budget</label>
                            <select id="search-budget" name="budget">
                                <option value="">Budget</option>
                                <option value="500000">Under ₱500k</option>
                                <option value="1000000">Under ₱1M</option>
                                <option value="2000000">Under ₱2M</option>
                            </select>
                        </div>
                        <button type="submit" class="primary">Search</button>
                    </form>
                </div>
			</section>

			<section id="trust-block">
				<h2>We document machines, not just list them</h2>
				<p>Basic specs aren't enough. Every Apex Engine listing is backed by an in-house technical audit — so you buy on evidence, not promises.</p>
				<ul class="standard">
					<li><span>✓</span> Verified odometer</li>
					<li><span>✓</span> Japan auction grade</li>
					<li><span>✓</span> Inspection report</li>
					<li><span>✓</span> EV/hybrid battery health</li>
				</ul>
				<p class="license">Licensed dealer #001</p>
			</section>

			<section id="featured-listings">
				<h2>Featured Listings</h2>
				<div class="listing-grid">
                    {featuredListings.map(item => <VehicleSpecCard data={item} />)}
                </div>
			</section>

			<section id="browse-category">
				<h2>Browse by Category</h2>
				<div class="grid">
                    <PandaCard title="Kei Trucks" />
                    <PandaCard title="Sports Cars" />
                    <PandaCard title="RHD Vans" />
                </div>
			</section>

			<section id="news-blog">
				<h2>Automotive News & Blog</h2>
				<div class="grid">
                    <PandaCard title="Toyota Vios vs Honda City" />
                    <PandaCard title="Top 5 Beginner JDM Imports" />
                </div>
			</section>

			<section id="how-to">
				<h2>How-To Guides</h2>
				<ul>
                    <li><a href="#">Toyota Vios Preventive Maintenance Schedule</a></li>
                    <li><a href="#">LTO Registration Renewal Guide 2026</a></li>
                </ul>
			</section>

			<section id="culture-hub">
				<h2>JDM Culture Hub</h2>
				<p>Stories on drift heritage and Touge culture in the Philippines.</p>
			</section>

			<section id="buyer-reviews">
				<h2>Buyer Reviews</h2>
				<blockquote>
					"Smooth process from import to delivery. Verified!"
					<footer>— John D.</footer>
				</blockquote>
			</section>

			<section id="closing-cta">
				<h2>Ready to Find Your Dream Car?</h2>
				<button class="primary">Browse Inventory</button>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
    /* ---- Hero ---- */
    #hero {
        position: relative;
        padding: 0;
        min-height: clamp(440px, 70vh, 640px);
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border-bottom: none;
    }
    /* Optimized <Image> sits behind the overlay as the LCP element */
    .hero-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 40%;
        z-index: 0;
    }
    .hero-overlay {
        position: relative;
        z-index: 1;
        background: rgba(17, 24, 39, 0.65);
        padding: clamp(2.5em, 8vw, 5em) 1em;
        text-align: center;
        width: 100%;
        backdrop-filter: blur(3px);
    }
    #hero h1 {
        color: var(--bg-color);
        font-size: clamp(2rem, 6vw, 3.5rem);
        max-width: 16ch;
        margin-inline: auto;
    }
    .hero-sub {
        color: rgba(255, 255, 255, 0.85);
        max-width: 52ch;
        margin: 0.5em auto 0;
        font-size: clamp(1rem, 2.5vw, 1.15rem);
    }

    /* ---- Quick search ---- */
    .quick-search {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75em;
        justify-content: center;
        background: var(--bg-color);
        padding: 1.25em;
        border: 2px solid var(--text-color);
        max-width: 820px;
        margin: 2em auto 0;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.25);
    }
    .quick-search .field {
        flex: 1 1 160px;
    }
    .quick-search select {
        width: 100%;
        padding: 0.65em;
        border: 1px solid var(--text-color);
        background: var(--bg-color);
        cursor: pointer;
        font: inherit;
    }
    .quick-search button {
        flex: 1 1 120px;
    }

    /* ---- Section rhythm: break the monotonous bordered-band stack ---- */
    main :global(section) {
        border-bottom: none;
        padding-block: clamp(2.5em, 6vw, 4em);
    }
    #trust-block {
        text-align: center;
        background: var(--mica-dark);
        color: var(--paper);
        margin-inline: calc(50% - 50vw);
        padding-inline: 1em;
    }
    #trust-block :global(h2) { color: var(--paper); max-width: 22ch; margin-inline: auto; }
    #trust-block p { color: rgba(255, 255, 255, 0.82); max-width: 60ch; margin-inline: auto; }
    #trust-block .standard {
        list-style: none;
        padding: 0;
        margin: 1.5em auto 0;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75em 1.5em;
        max-width: 760px;
    }
    #trust-block .standard li {
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.03em;
        font-size: 0.85rem;
    }
    #trust-block .standard span {
        color: var(--red-mica);
        margin-right: 0.35em;
    }
    #trust-block .license {
        margin-top: 1.75em;
        font-size: 0.8rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--metal-gray-light);
    }

    #buyer-reviews blockquote {
        font-size: 1.25em;
        border-left: 4px solid var(--accent-color);
        margin: 1em 0 0;
        padding-left: 1em;
        font-style: italic;
    }

    #closing-cta { text-align: center; }

    #how-to ul {
        list-style: none;
        padding: 0;
        margin-top: 1em;
        display: grid;
        gap: 0.5em;
    }
    #how-to li a {
        display: block;
        padding: 0.75em 1em;
        border: 1px solid var(--metal-gray);
        text-decoration: none;
    }
    #how-to li a:hover { border-color: var(--accent-color); }

    /* ---- Featured listings: self-contained grid, no shared-class conflict ----
       Uses its own class so the global `.grid` rules (and any cached CSS) can't
       fight it. 8 cards => 2 rows x 4 on laptops+. */
    .listing-grid {
        display: grid;
        gap: 1.5em;
        margin-top: 2em;
        grid-template-columns: 1fr;
    }
    @media (min-width: 700px) {
        .listing-grid { grid-template-columns: repeat(4, 1fr); }
    }

    /* ---- Other homepage grids (category / news) ---- */
    .grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5em;
        margin-top: 2em;
    }
    @media (min-width: 600px) {
        .grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (min-width: 700px) {
        #browse-category .grid { grid-template-columns: repeat(3, 1fr); }
    }

    /* ---- Visible keyboard focus across interactive homepage elements ---- */
    .quick-search :is(select, button):focus-visible,
    #how-to a:focus-visible {
        outline: 3px solid var(--accent-color);
        outline-offset: 2px;
    }
</style>
