---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import VehicleSpecCard from '../components/VehicleSpecCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { listings } from '../data/listings';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Listings | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section>
				<h1>Inventory</h1>
				<p id="results-bar" class="results-bar" aria-live="polite"></p>

				<div class="grid">
					{listings.map((item) => (
						<div
							class="listing-item"
							data-make={item.make.toLowerCase()}
							data-model={item.model.toLowerCase()}
							data-price={item.price}
						>
							<VehicleSpecCard data={item} />
						</div>
					))}
				</div>

				<p id="empty-state" class="empty-state" hidden>
					No cars match your filters. <a href="/listings">Reset</a>
				</p>
			</section>
		</main>
		<Footer />

		<script>
			// Static-site friendly: filter the rendered listings from the URL query.
			const params = new URLSearchParams(location.search);
			const fMake = (params.get('make') || '').toLowerCase();
			const fModel = (params.get('model') || '').toLowerCase();
			const fBudget = Number(params.get('budget') || 0);

			const items = Array.from(document.querySelectorAll<HTMLElement>('.listing-item'));
			let shown = 0;
			for (const el of items) {
				const okMake = !fMake || el.dataset.make === fMake;
				const okModel = !fModel || el.dataset.model === fModel;
				const okBudget = !fBudget || Number(el.dataset.price) <= fBudget;
				const show = okMake && okModel && okBudget;
				el.hidden = !show;
				if (show) shown++;
			}

			const filtered = Boolean(fMake || fModel || fBudget);
			const bar = document.getElementById('results-bar')!;
			const empty = document.getElementById('empty-state')!;
			const noun = (n: number) => (n === 1 ? 'car' : 'cars');

			if (filtered) {
				bar.innerHTML = `<span>${shown} ${noun(shown)} match your filters</span> <a href="/listings">Clear filters</a>`;
			} else {
				bar.innerHTML = `<span>${items.length} ${noun(items.length)} available</span>`;
			}
			empty.hidden = shown !== 0;
		</script>
	</body>
</html>

<style>
	.results-bar {
		display: flex;
		gap: 1em;
		align-items: baseline;
		margin: 0;
		color: var(--metal-gray);
		font-size: 0.95rem;
	}
	.results-bar a {
		color: var(--red-mica);
		font-weight: 700;
		text-decoration: none;
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2em;
		margin-top: 1.5em;
	}
	.listing-item[hidden] {
		display: none;
	}
	.empty-state {
		margin-top: 2em;
		padding: 2em;
		border: 1px dashed var(--metal-gray);
		text-align: center;
		color: var(--metal-gray);
	}
	.empty-state a {
		color: var(--red-mica);
		font-weight: 700;
	}
</style>
