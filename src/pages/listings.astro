---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import VehicleSpecCard from '../components/VehicleSpecCard.astro';
import { listings, makes, modelsByMake, CATEGORIES, LISTINGS_LIVE } from '../data/listings';

// See CONTENT_STYLE_GUIDE.md's meta title/description formula — these two
// variants must each independently satisfy the 55-58 / 155-158 char rule.
const pageTitle = LISTINGS_LIVE
	? 'Verified Used Car Inventory Listings in PH - Apex Engine'
	: 'Trusted Used Car Inventory Launching Soon - Apex Engine';
const pageDescription = LISTINGS_LIVE
	? "Apex Engine's inventory ships with a verified odometer, Japan auction grade, and full inspection report on every unit sold. Browse the verified listings now."
	: "Apex Engine's verified inventory is launching soon — every unit ships with a verified odometer, Japan auction grade, and a full inspection report. Stay tuned.";
---

<!doctype html>
<html lang="en-PH">
	<head>
		<BaseHead title={pageTitle} description={pageDescription} noindex={!LISTINGS_LIVE} />
	</head>
	<body>
		<Header />
		<main>
			{!LISTINGS_LIVE && (
			<section class="coming-soon">
				<span class="cs-badge">Coming Soon</span>
				<h1>Our inventory is being documented</h1>
				<p class="lead">Apex Engine doesn't just list cars — we document machines. Before the first unit goes live, every car is put through a full technical audit, so you buy on evidence, not promises.</p>
				<ul class="standard">
					<li><span>✓</span> Verified odometer</li>
					<li><span>✓</span> Japan auction grade</li>
					<li><span>✓</span> Inspection report</li>
					<li><span>✓</span> EV/hybrid battery health</li>
				</ul>
				<p class="meanwhile">In the meantime, dig into our buyer's guides:</p>
				<div class="cs-actions">
					<a href="/blog" class="cta-link"><button class="primary">Read the Blog</button></a>
					<a href="/contact" class="cta-link"><button>Get Notified at Launch</button></a>
				</div>
				<p class="license">Licensed dealer #001</p>
			</section>
			)}
			{LISTINGS_LIVE && (
			<section class="listings-section">
				<h1>Inventory</h1>

				<!-- Inline Filter Panel -->
				<div class="filter-panel">
					<form id="filter-form" class="filter-form" action="/listings" method="get">
						<div class="field">
							<label for="filter-category">Category</label>
							<select id="filter-category" name="category">
								<option value="">All Categories</option>
								{CATEGORIES.map((c) => <option value={c.slug}>{c.label}</option>)}
							</select>
						</div>
						<div class="field">
							<label for="filter-make">Make</label>
							<select id="filter-make" name="make">
								<option value="">All Makes</option>
								{makes.map((m) => <option value={m.toLowerCase()}>{m}</option>)}
							</select>
						</div>
						<div class="field">
							<label for="filter-model">Model</label>
							<select id="filter-model" name="model" disabled>
								<option value="">All Models</option>
							</select>
						</div>
						<div class="field">
							<label for="filter-budget">Max Budget</label>
							<select id="filter-budget" name="budget">
								<option value="">No Budget Limit</option>
								<option value="500000">Under ₱500k</option>
								<option value="1000000">Under ₱1M</option>
								<option value="2000000">Under ₱2M</option>
								<option value="5000000">Under ₱5M</option>
							</select>
						</div>
						<button type="submit" class="primary">Apply Filters</button>
					</form>
				</div>

				<p id="results-bar" class="results-bar" aria-live="polite"></p>

				<div class="grid">
					{listings.map((item) => (
						<div
							class="listing-item"
							data-make={item.make.toLowerCase()}
							data-model={item.model.toLowerCase()}
							data-category={item.category}
							data-price={item.price}
						>
							<VehicleSpecCard data={item} />
						</div>
					))}
				</div>

				<p id="empty-state" class="empty-state" hidden>
					No cars match your filters. <a href="/listings">Reset Filters</a>
				</p>
			</section>
			)}
		</main>
		<Footer />

		{LISTINGS_LIVE && (
		<script define:vars={{ modelsByMake }}>
			// Static-site friendly: filter the rendered listings from the URL query.
			const params = new URLSearchParams(location.search);
			const fCategory = (params.get('category') || '').toLowerCase();
			const fMake = (params.get('make') || '').toLowerCase();
			const fModel = (params.get('model') || '').toLowerCase();
			const fBudget = Number(params.get('budget') || 0);

			// Populate dropdown selections on load
			const categorySel = document.getElementById('filter-category');
			const makeSel = document.getElementById('filter-make');
			const modelSel = document.getElementById('filter-model');
			const budgetSel = document.getElementById('filter-budget');

			if (categorySel) categorySel.value = fCategory;
			if (makeSel) makeSel.value = fMake;
			if (budgetSel) budgetSel.value = fBudget ? String(fBudget) : '';

			function fillModels() {
				const makeVal = makeSel.value;
				const models = modelsByMake[makeVal] || [];
				modelSel.innerHTML =
					'<option value="">All Models</option>' +
					models.map((m) => `<option value="${m.toLowerCase()}">${m}</option>`).join('');
				modelSel.disabled = models.length === 0;
				
				// Keep current selected model if it exists in list
				if (models.length > 0 && fModel && models.map(m => m.toLowerCase()).includes(fModel)) {
					modelSel.value = fModel;
				}
			}

			if (makeSel && modelSel) {
				makeSel.addEventListener('change', fillModels);
				fillModels();
			}

			const items = Array.from(document.querySelectorAll('.listing-item'));
			let shown = 0;
			for (const el of items) {
				const okCategory = !fCategory || el.dataset.category === fCategory;
				const okMake = !fMake || el.dataset.make === fMake;
				const okModel = !fModel || el.dataset.model === fModel;
				const okBudget = !fBudget || Number(el.dataset.price) <= fBudget;
				const show = okCategory && okMake && okModel && okBudget;
				el.hidden = !show;
				if (show) shown++;
			}

			const filtered = Boolean(fCategory || fMake || fModel || fBudget);
			const bar = document.getElementById('results-bar');
			const empty = document.getElementById('empty-state');
			const noun = (n) => (n === 1 ? 'car' : 'cars');

			if (bar) {
				if (filtered) {
					bar.innerHTML = `<span>Found ${shown} ${noun(shown)} matching your criteria</span> <a href="/listings">Clear filters</a>`;
				} else {
					bar.innerHTML = `<span>Showing all ${items.length} available units</span>`;
				}
			}
			if (empty) {
				empty.hidden = shown !== 0;
			}
		</script>
		)}
	</body>
</html>

<style>
	/* ---- Coming Soon state ---- */
	.coming-soon {
		max-width: 680px;
		margin: clamp(2em, 8vw, 5em) auto;
		text-align: center;
		padding: 0 1em;
	}
	.coming-soon .cs-badge {
		display: inline-block;
		background: var(--accent-color);
		color: var(--paper);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		font-size: 0.8rem;
		padding: 0.35em 0.9em;
		border-radius: 999px;
	}
	.coming-soon h1 {
		margin: 0.6em 0 0.3em;
		font-size: clamp(1.8rem, 5vw, 2.6rem);
	}
	.coming-soon .lead {
		color: var(--metal-gray);
		max-width: 52ch;
		margin: 0 auto;
	}
	.coming-soon .standard {
		list-style: none;
		padding: 0;
		margin: 2em auto 0;
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.75em 1.5em;
		max-width: 520px;
	}
	.coming-soon .standard li {
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.03em;
		font-size: 0.85rem;
	}
	.coming-soon .standard span { color: var(--accent-color); margin-right: 0.35em; }
	.coming-soon .meanwhile { margin: 2.5em 0 1em; color: var(--metal-gray); }
	.coming-soon .cs-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1em;
		justify-content: center;
	}
	.coming-soon .license {
		margin-top: 2.5em;
		font-size: 0.8rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--metal-gray-light);
	}

	.listings-section {
		padding: 2em 0;
	}
	.filter-panel {
		background: var(--paper-off);
		border: 1px solid var(--line);
		padding: 1.5em;
		margin-bottom: 2em;
		margin-top: 1em;
	}
	.filter-form {
		display: flex;
		flex-wrap: wrap;
		gap: 1.25em;
		align-items: flex-end;
	}
	.filter-form .field {
		flex: 1 1 180px;
		display: flex;
		flex-direction: column;
		gap: 0.4em;
	}
	.filter-form label {
		font-size: 0.75rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--metal-gray);
	}
	.filter-form select {
		width: 100%;
		padding: 0.65em;
		border: 1px solid var(--metal-gray-light);
		background: var(--paper);
		cursor: pointer;
		font: inherit;
	}
	.filter-form select:focus-visible {
		outline: 2px solid var(--accent-color);
	}
	.filter-form button {
		flex: 1 1 120px;
		padding: 0.7em 1.5em;
	}

	.results-bar {
		display: flex;
		gap: 1em;
		align-items: baseline;
		margin: 0;
		color: var(--metal-gray);
		font-size: 0.95rem;
		border-bottom: 2px solid var(--black-mica);
		padding-bottom: 0.5em;
	}
	.results-bar :global(a) {
		color: var(--red-mica);
		font-weight: 700;
		text-decoration: none;
	}
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2em;
		margin-top: 1.5em;
	}
	.listing-item[hidden] {
		display: none;
	}
	.empty-state {
		margin-top: 2em;
		padding: 3em;
		border: 1px dashed var(--metal-gray);
		text-align: center;
		color: var(--metal-gray);
	}
	.empty-state a {
		color: var(--red-mica);
		font-weight: 700;
	}
</style>
