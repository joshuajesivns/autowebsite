---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import VehicleSpecCard from '../../components/VehicleSpecCard.astro';
import { getCollection, render } from 'astro:content';
import { listings } from '../../data/listings';

export async function getStaticPaths() {
	const modelEntries = await getCollection('models');
	return modelEntries.map((entry) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { make, model, yearsProduced, engine, transmission, fuel, seats, bodyType, averageMarketPrice } = entry.data;

// Render markdown body
const { Content } = await render(entry);

// Query active listings for this model
const activeListings = listings.filter(
	(l) => l.make.toLowerCase() === make.toLowerCase() && l.model.toLowerCase().includes(model.toLowerCase().split(' ')[0])
);

// Query blog articles relating to this make or model
const allBlogs = await getCollection('blog');
const relatedBlogs = allBlogs.filter((post) => {
	const text = (post.data.title + ' ' + post.data.description).toLowerCase();
	const matchMake = text.includes(make.toLowerCase());
	const matchModel = text.includes(model.toLowerCase().split(' ')[0]);
	const matchTag = post.data.tags?.some(tag => 
		tag.toLowerCase() === make.toLowerCase() || 
		tag.toLowerCase() === model.toLowerCase()
	);
	return matchMake || matchModel || matchTag;
}).slice(0, 3);
---

<!doctype html>
<html lang="en-PH">
	<head>
		<BaseHead title={`${make} ${model} Reviews, Specs & Guides | Apex Engine`} description={`Read our technical audit, specifications, and buying guides for the ${make} ${model}.`} />
	</head>
	<body>
		<Header />
		<main>
			<div class="breadcrumb">
				<a href="/models" class="back-link">← Model Catalog</a>
			</div>

			<!-- Dynamic Title Banner -->
			<div class="model-banner">
				<span class="category-badge">{bodyType} Hub</span>
				<h1>{make} {model}</h1>
				<p class="years">Production Years: {yearsProduced}</p>
			</div>

			<div class="model-grid">
				<!-- Left: Review Body -->
				<article class="prose">
					<Content />
				</article>

				<!-- Right: Specs Card -->
				<aside class="specs-aside">
					<div class="specs-card">
						<h3>Technical Reference</h3>
						<ul class="specs-list">
							<li>
								<span>Manufacturer</span>
								<strong>{make}</strong>
							</li>
							<li>
								<span>Model Series</span>
								<strong>{model}</strong>
							</li>
							<li>
								<span>Engine Layout</span>
								<strong>{engine}</strong>
							</li>
							<li>
								<span>Transmission</span>
								<strong>{transmission}</strong>
							</li>
							<li>
								<span>Fuel Type</span>
								<strong>{fuel}</strong>
							</li>
							<li>
								<span>Seating</span>
								<strong>{seats} Seats</strong>
							</li>
							<li>
								<span>Est. Market Price</span>
								<strong class="price-highlight">{averageMarketPrice}</strong>
							</li>
						</ul>
					</div>

					<div class="lead-generation-box">
						<h4>Want to source one?</h4>
						<p>We work with trusted local importers to inspect and verify vehicles before they ship. Let us know what you are looking for.</p>
						<a href="/contact" class="button primary block text-center">Inquire Sourcing</a>
					</div>
				</aside>
			</div>

			<!-- Active Inventory / Dealer Section -->
			<section class="related-inventory">
				<h2>Units Currently For Sale</h2>
				{activeListings.length > 0 ? (
					<div class="listings-grid">
						{activeListings.map((item) => (
							<VehicleSpecCard data={item} />
						))}
					</div>
				) : (
					<div class="empty-inventory-cta">
						<div class="cta-content">
							<p>No verified dealer listings are currently active for the <strong>{make} {model}</strong> in our inventory.</p>
							<p class="sub">Are you an accredited dealer or private collector with a clean unit? Get it audited and listed on Apex Engine to reach serious buyers.</p>
						</div>
						<a href="/contact" class="button text-center">List Your Vehicle</a>
					</div>
				)}
			</section>

			<!-- Related Articles Section -->
			{relatedBlogs.length > 0 && (
				<section class="related-articles-section">
					<h2>Related Articles & Guides</h2>
					<div class="articles-grid">
						{relatedBlogs.map((post) => (
							<a href={`/blog/${post.id}/`} class="article-card">
								{post.data.heroImage && (
									<img src={post.data.heroImage.src} alt={post.data.title} class="article-thumb" />
								)}
								<div class="article-info">
									<h4>{post.data.title}</h4>
									<p>{post.data.description}</p>
									<span class="read-more">Read Article →</span>
								</div>
							</a>
						))}
					</div>
				</section>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	.breadcrumb {
		margin-bottom: 1.5em;
	}
	.back-link {
		display: inline-flex;
		align-items: center;
		color: var(--metal-gray);
		text-decoration: none;
		font-weight: 700;
		font-size: 0.9rem;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.back-link:hover {
		color: var(--accent-color);
	}

	.model-banner {
		margin-bottom: 3em;
		border-bottom: 3px solid var(--black-mica);
		padding-bottom: 1.5em;
	}
	.category-badge {
		font-size: 0.7rem;
		font-weight: 700;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		background: var(--red-mica);
		color: var(--paper);
		padding: 0.3em 0.6em;
		display: inline-block;
		margin-bottom: 0.75em;
	}
	.model-banner h1 {
		font-size: 3.5em;
		text-transform: uppercase;
		margin: 0;
		line-height: 1;
	}
	.years {
		color: var(--metal-gray);
		font-size: 1.1rem;
		margin: 0.35em 0 0;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-weight: 500;
	}

	.model-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3em;
		margin-bottom: 4em;
	}
	@media (min-width: 900px) {
		.model-grid {
			grid-template-columns: 1.4fr 1fr;
		}
	}

	/* Prose details */
	.prose :global(h2) {
		font-size: 1.75em;
		margin-top: 1.5em;
		margin-bottom: 0.5em;
		text-transform: uppercase;
		border-top: 1px solid var(--line);
		padding-top: 1em;
	}
	.prose :global(p) {
		line-height: 1.6;
		margin-bottom: 1.25em;
		color: rgba(17, 24, 39, 0.85);
	}
	.prose :global(ul) {
		margin-bottom: 1.5em;
		padding-left: 1.25em;
		line-height: 1.6;
	}
	.prose :global(li) {
		margin-bottom: 0.5em;
	}

	/* Specs sidebar */
	.specs-aside {
		display: flex;
		flex-direction: column;
		gap: 2em;
	}
	.specs-card {
		border: 1px solid var(--line);
		padding: 1.5em;
		background: var(--paper-off);
	}
	.specs-card h3 {
		font-size: 1.2rem;
		text-transform: uppercase;
		border-bottom: 2px solid var(--black-mica);
		padding-bottom: 0.5em;
		margin-bottom: 1em;
	}
	.specs-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 1em;
	}
	.specs-list li {
		display: flex;
		justify-content: space-between;
		border-bottom: 1px dashed var(--line);
		padding-bottom: 0.5em;
		font-size: 0.9rem;
	}
	.specs-list span {
		color: var(--metal-gray);
		text-transform: uppercase;
		font-size: 0.75rem;
		font-weight: 700;
		letter-spacing: 0.05em;
	}
	.specs-list strong {
		font-family: monospace;
	}
	.price-highlight {
		color: var(--red-mica);
	}

	.lead-generation-box {
		border: 1px solid var(--line);
		padding: 1.5em;
		background: var(--paper);
	}
	.lead-generation-box h4 {
		text-transform: uppercase;
		font-size: 1.1rem;
		margin-bottom: 0.5em;
	}
	.lead-generation-box p {
		font-size: 0.85rem;
		color: var(--metal-gray);
		margin-bottom: 1.25em;
		line-height: 1.5;
	}
	.button.primary.block {
		display: block;
		text-decoration: none;
	}

	/* Listings Grid */
	.related-inventory {
		border-top: 1px solid var(--line);
		padding-top: 3em;
		margin-bottom: 4em;
	}
	.related-inventory h2 {
		text-transform: uppercase;
		margin-bottom: 1.5em;
	}
	.listings-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2em;
	}
	@media (min-width: 600px) {
		.listings-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	@media (min-width: 900px) {
		.listings-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}
	.empty-inventory-cta {
		border: 1px dashed var(--metal-gray-light);
		padding: 3em;
		text-align: center;
		background: var(--paper-off);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5em;
	}
	.cta-content p {
		margin: 0;
		font-size: 1.05rem;
	}
	.cta-content .sub {
		margin-top: 0.5em;
		font-size: 0.85rem;
		color: var(--metal-gray);
	}
	.empty-inventory-cta .button {
		padding: 0.8em 2em;
		background: var(--black-mica);
		color: var(--paper);
		text-decoration: none;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
	.empty-inventory-cta .button:hover {
		background: var(--accent-color);
	}

	/* Related Articles */
	.related-articles-section {
		border-top: 1px solid var(--line);
		padding-top: 3em;
		margin-bottom: 2em;
	}
	.related-articles-section h2 {
		text-transform: uppercase;
		margin-bottom: 1.5em;
	}
	.articles-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5em;
	}
	@media (min-width: 768px) {
		.articles-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}
	.article-card {
		border: 1px solid var(--line);
		text-decoration: none;
		color: inherit;
		background: var(--paper);
		display: flex;
		flex-direction: column;
		transition: border-color 0.15s, box-shadow 0.15s;
	}
	.article-card:hover {
		border-color: var(--black-mica);
		box-shadow: 0 5px 15px rgba(0,0,0,0.05);
	}
	.article-thumb {
		width: 100%;
		aspect-ratio: 16 / 10;
		object-fit: cover;
		border-bottom: 1px solid var(--line);
	}
	.article-info {
		padding: 1.25em;
		display: flex;
		flex-direction: column;
		height: 100%;
	}
	.article-info h4 {
		margin: 0 0 0.5em 0;
		font-size: 1.1rem;
		text-transform: uppercase;
		line-height: 1.2;
	}
	.article-info p {
		font-size: 0.85rem;
		color: var(--metal-gray);
		margin: 0 0 1.25em 0;
		line-height: 1.5;
		flex-grow: 1;
	}
	.read-more {
		font-size: 0.8rem;
		font-weight: 700;
		color: var(--accent-color);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}
</style>
