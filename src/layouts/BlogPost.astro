---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import '../styles/apex.css';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" is:inline set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "BlogPosting",
			"headline": title,
			"description": description,
			"image": heroImage ? new URL(heroImage.src, Astro.url) : undefined,
			"datePublished": pubDate.toISOString(),
			"dateModified": (updatedDate || pubDate).toISOString(),
			"author": {
				"@type": "Organization",
				"name": "Apex Engine Editorial Team"
			}
		})} />
	</head>

	<body>
		<Header />
		<main>
			<article>
                <header class="blog-hero">
                    {heroImage && (
                        <div class="hero-bg-container">
                            <Image width={1920} height={1080} src={heroImage} alt="" class="hero-bg-img" />
                            <div class="hero-overlay"></div>
                        </div>
                    )}
                    <div class="hero-content">
                        <div class="date">
                            <FormattedDate date={pubDate} />
                        </div>
                        <h1>{title}</h1>
                        <p class="description">{description}</p>
                    </div>
                </header>
                
                <div class="layout-container">
                    <aside class="sticky-toc">
                        <div class="toc-card">
                            <h3>Specifications & Documentation</h3>
                            <p>Technical review of the {title.split(':')[0]}.</p>
                        </div>
                    </aside>
                    
                    <div class="prose">
                        <slot />
                        
                        <div class="author-block">
                            <h3>About the Author</h3>
                            <p>Expert automotive content by Apex Engine Editorial Team. Last updated: {updatedDate || pubDate}</p>
                        </div>
                    </div>
                </div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
    /* --- Hero Section --- */
    .blog-hero {
        position: relative;
        min-height: 50vh;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--paper);
        text-align: center;
        padding: 4em 1em;
        margin-bottom: 3em;
        background: var(--black-mica);
        overflow: hidden;
    }
    .hero-bg-container {
        position: absolute;
        inset: 0;
        z-index: 0;
    }
    .hero-bg-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.4;
    }
    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, transparent, var(--black-mica));
    }
    .hero-content {
        position: relative;
        z-index: 1;
        max-width: 900px;
    }
    .blog-hero h1 {
        color: var(--paper);
        font-size: clamp(2.5rem, 8vw, 4rem);
        line-height: 1;
        margin: 0.2em 0 0.5em;
        text-transform: uppercase;
        letter-spacing: -0.03em;
    }
    .blog-hero .description {
        font-size: 1.25rem;
        color: var(--metal-gray-light);
        max-width: 60ch;
        margin: 0 auto;
    }
    .blog-hero .date {
        color: var(--red-mica);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.9rem;
    }

    /* --- Body Content --- */
    .layout-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3em;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5em;
    }
    @media (min-width: 1024px) {
        .layout-container {
            grid-template-columns: 280px 1fr;
        }
    }

    .sticky-toc {
        display: none;
    }
    @media (min-width: 1024px) {
        .sticky-toc {
            display: block;
            position: sticky;
            top: 2em;
            height: fit-content;
        }
    }
    .toc-card {
        background: var(--paper-off);
        border-left: 4px solid var(--red-mica);
        padding: 1.5em;
    }
    .toc-card h3 {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1em;
    }
    .toc-card p {
        font-size: 0.9rem;
        color: var(--metal-gray);
        margin: 0;
    }

    .prose {
        font-size: 1.125rem;
        line-height: 1.7;
        color: var(--black-mica-2);
    }
    
    /* Rhythm for sections - targeting subheadings */
    :global(.prose h2) {
        font-size: 2rem;
        margin-top: 2.5em;
        padding-top: 1em;
        border-top: 1px solid var(--line);
        display: flex;
        align-items: baseline;
        gap: 0.5em;
    }
    :global(.prose h2::before) {
        content: "/";
        color: var(--red-mica);
        font-weight: 900;
    }

    :global(.prose p) {
        margin-bottom: 1.5em;
    }

    .author-block {
        border-top: 4px solid var(--black-mica);
        background: var(--paper-off);
        margin-top: 4em;
        padding: 2em;
    }
    .author-block h3 {
        font-size: 1.1rem;
        margin-bottom: 0.5em;
    }
    .author-block p {
        margin: 0;
        font-size: 0.95rem;
        color: var(--metal-gray);
    }

    /* Data-friendly table styling */
    :global(.prose table) {
        width: 100%;
        border-collapse: collapse;
        margin: 2em 0;
    }
    :global(.prose th) {
        background-color: var(--text-color);
        color: var(--bg-color);
        padding: 0.75em;
        text-align: left;
    }
    :global(.prose td) {
        border: 1px solid #E5E5E5;
        padding: 0.75em;
    }
</style>
