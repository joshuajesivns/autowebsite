---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_URL } from '../consts';
import { buildBlogGraph, showsProducts } from '../lib/schema';
import '../styles/apex.css';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, heroAlt, faq, tags, vertical, vehicle, pms, featuredProducts } =
	Astro.props;

// ── Structured data ────────────────────────────────────────────────────────
// The whole @graph is assembled by the shared engine in src/lib/schema.ts, which
// picks the entity mix from `vertical`. We only resolve the Astro-specific bits
// (absolute canonical URL + processed hero image path) and hand it plain data.
const siteHref = Astro.site?.href ?? `${SITE_URL}/`; // trailing slash (astro trailingSlash:'always')
const pageUrl = new URL(Astro.url.pathname, Astro.site).href; // canonical, trailing slash
const graph = buildBlogGraph({
	vertical,
	title,
	description,
	pageUrl,
	siteHref,
	imageUrl: heroImage ? new URL(heroImage.src, Astro.url).href : undefined,
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate || pubDate).toISOString(),
	tags,
	faq,
	vehicle,
	pms,
	featuredProducts,
});

// Visible product section renders under the same rule the schema uses, so the
// cards and the ItemList markup can never disagree.
const showProducts = showsProducts(vertical) && !!(featuredProducts && featuredProducts.length);
---

<html lang="en-PH">
	<head>
		<BaseHead title={title} description={description} />
		<!-- One linked @graph: Article + Vehicle + FAQPage (+ Products when present) -->
		<script type="application/ld+json" is:inline set:html={JSON.stringify(graph)} />
	</head>

	<body>
		<Header />
		<main>
			<article>
                <header class="blog-hero">
                    {heroImage && (
                        <div class="hero-bg-container">
                            <Image width={1920} height={1080} src={heroImage} alt={heroAlt ?? ""} class="hero-bg-img" />
                            <div class="hero-overlay"></div>
                        </div>
                    )}
                    <div class="hero-content">
                        <div class="date">
                            {updatedDate && updatedDate.valueOf() !== pubDate.valueOf()
                                ? (<>Updated <FormattedDate date={updatedDate} /></>)
                                : (<FormattedDate date={pubDate} />)}
                        </div>
                        <h1>{title}</h1>
                        <p class="description">{description}</p>
                    </div>
                </header>
                
                <div class="layout-container">
                    <aside class="sticky-toc">
                        <div class="toc-card">
                            <h3>Specifications & Documentation</h3>
                            <p>Technical review of the {title.split(':')[0]}.</p>
                        </div>
                    </aside>
                    
                    <div class="prose">
                        <slot />

                        {showProducts && (
                            <section class="products">
                                <h2>Recommended Parts & Upgrades</h2>
                                <p class="affiliate-disclosure">Some links below are affiliate links — we may earn a small commission at no extra cost to you. We only recommend parts we'd fit ourselves.</p>
                                <div class="product-grid">
                                    {featuredProducts.map((p) => (
                                        <a class="product-card" href={p.url} rel="sponsored nofollow noopener" target="_blank">
                                            {p.category && <span class="product-cat">{p.category}</span>}
                                            <h3>{p.name}</h3>
                                            {p.brand && <span class="product-brand">{p.brand}</span>}
                                            {p.description && <p>{p.description}</p>}
                                            <span class="product-cta">View part →</span>
                                        </a>
                                    ))}
                                </div>
                            </section>
                        )}

                        {faq && faq.length > 0 && (
                            <section class="faq">
                                <h2>Frequently Asked Questions</h2>
                                {faq.map((item) => (
                                    <details class="faq-item">
                                        <summary>{item.q}</summary>
                                        <p>{item.a}</p>
                                    </details>
                                ))}
                            </section>
                        )}

                        <div class="author-block">
                            <h3>About the Author</h3>
                            <p>Expert automotive content by Apex Engine Editorial Team. Last updated: <FormattedDate date={updatedDate || pubDate} /></p>
                        </div>
                    </div>
                </div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
    /* --- Hero Section --- */
    .blog-hero {
        position: relative;
        min-height: 50vh;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--paper);
        text-align: center;
        padding: 4em 1em;
        margin-bottom: 3em;
        background: var(--black-mica);
        overflow: hidden;
    }
    .hero-bg-container {
        position: absolute;
        inset: 0;
        z-index: 0;
    }
    .hero-bg-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.3;
        filter: grayscale(100%) brightness(0.8);
    }
    .hero-overlay {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, transparent, var(--black-mica));
    }
    .hero-content {
        position: relative;
        z-index: 1;
        max-width: 1000px;
        padding: 0 1.5em;
    }
    .blog-hero h1 {
        color: var(--paper);
        font-size: clamp(2.5rem, 8vw, 4.5rem);
        line-height: 0.95;
        margin: 0.2em 0 0.3em;
        text-transform: uppercase;
        font-weight: 900;
        letter-spacing: -0.05em;
    }
    .blog-hero .description {
        font-size: clamp(1.1rem, 3vw, 1.4rem);
        color: var(--metal-gray-light);
        max-width: 50ch;
        margin: 0 auto;
        line-height: 1.4;
    }
    .blog-hero .date {
        color: var(--red-mica);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 0.9rem;
    }

    /* --- Body Content --- */
    .layout-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: 3em;
        max-width: 1200px;
        margin: 0 auto 5em;
        padding: 0 1.5em;
        /* Drives the <Figure width="full"> breakout. On mobile there's no
           sidebar, so "full" reaches the container padding edges. */
        --bleed-left: 1.5em;
        --bleed-right: 1.5em;
    }
    @media (min-width: 1024px) {
        .layout-container {
            grid-template-columns: 280px 1fr;
            /* Reclaim the 280px TOC sidebar + 3em gap on the left so a full-width
               figure spans the whole content row. */
            --bleed-left: calc(280px + 3em);
            --bleed-right: 0px;
        }
    }

    .sticky-toc {
        display: none;
    }
    @media (min-width: 1024px) {
        .sticky-toc {
            display: block;
            position: sticky;
            top: 2em;
            height: fit-content;
        }
    }
    .toc-card {
        background: var(--paper-off);
        border-left: 4px solid var(--red-mica);
        padding: 1.5em;
    }
    .toc-card h3 {
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1em;
    }
    .toc-card p {
        font-size: 0.9rem;
        color: var(--metal-gray);
        margin: 0;
    }

    .prose {
        font-size: 1.125rem;
        line-height: 1.7;
        color: var(--black-mica-2);
    }
    
    /* Rhythm for sections - targeting subheadings */
    :global(.prose h2) {
        font-size: 2rem;
        margin-top: 2.5em;
        padding-top: 1em;
        border-top: 1px solid var(--line);
        display: flex;
        align-items: baseline;
        gap: 0.5em;
    }
    :global(.prose h2::before) {
        content: "/";
        color: var(--red-mica);
        font-weight: 900;
    }

    :global(.prose p) {
        margin-bottom: 1.5em;
    }

    /* Base styling for content authored as plain markdown (images, lists,
       links, rules, quotes). The editorial components override these as needed. */
    :global(.prose img) {
        max-width: 100%;
        height: auto;
        display: block;
    }
    :global(.prose figure) {
        margin: 2.5em 0;
    }
    :global(.prose figcaption) {
        margin-top: 0.5em;
        font-size: 0.85rem;
        color: var(--metal-gray);
    }
    :global(.prose ul),
    :global(.prose ol) {
        margin: 0 0 1.5em;
        padding-left: 1.25em;
        line-height: 1.7;
    }
    :global(.prose li) {
        margin-bottom: 0.5em;
    }
    :global(.prose a) {
        color: var(--red-mica);
        text-decoration: underline;
        text-underline-offset: 2px;
    }
    :global(.prose hr) {
        border: none;
        border-top: 1px solid var(--line);
        margin: 3em 0;
    }
    :global(.prose blockquote) {
        margin: 2em 0;
        padding-left: 1.25em;
        border-left: 4px solid var(--line);
        color: var(--metal-gray);
        font-style: italic;
    }

    .author-block {
        border-top: 4px solid var(--black-mica);
        background: var(--paper-off);
        margin-top: 4em;
        padding: 2em;
    }
    .author-block h3 {
        font-size: 1.1rem;
        margin-bottom: 0.5em;
    }
    .author-block p {
        margin: 0;
        font-size: 0.95rem;
        color: var(--metal-gray);
    }

    /* Recommended products — visible cards paired with ItemList/Product schema.
       Both render from the same `featuredProducts` frontmatter, so schema never
       describes a product the reader can't see. */
    .products {
        margin-top: 3em;
        border-top: 4px solid var(--black-mica);
        padding-top: 1.5em;
    }
    .products h2 {
        font-size: 1.5rem;
        text-transform: uppercase;
        margin-bottom: 0.5em;
    }
    .affiliate-disclosure {
        font-size: 0.85rem;
        color: var(--metal-gray);
        margin-bottom: 1.5em;
    }
    .product-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1em;
    }
    .product-card {
        display: flex;
        flex-direction: column;
        gap: 0.35em;
        background: var(--paper-off);
        border-left: 4px solid var(--red-mica);
        padding: 1.25em;
        text-decoration: none;
        color: var(--black-mica-2);
        transition: transform 0.15s ease;
    }
    .product-card:hover {
        transform: translateY(-2px);
    }
    .product-card h3 {
        font-size: 1.05rem;
        margin: 0;
    }
    .product-cat {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--red-mica);
        font-weight: 700;
    }
    .product-brand {
        font-size: 0.85rem;
        color: var(--metal-gray);
    }
    .product-card p {
        font-size: 0.9rem;
        margin: 0.25em 0 0;
    }
    .product-cta {
        margin-top: auto;
        padding-top: 0.5em;
        font-weight: 700;
        color: var(--red-mica);
    }

    /* FAQ — visible Q&A, paired with FAQPage schema for AI Overviews */
    .faq {
        margin-top: 3em;
        border-top: 4px solid var(--black-mica);
        padding-top: 1.5em;
    }
    .faq h2 {
        font-size: 1.5rem;
        text-transform: uppercase;
        margin-bottom: 0.75em;
    }
    .faq-item {
        border-bottom: 1px solid var(--line);
        padding: 0.75em 0;
    }
    .faq-item summary {
        cursor: pointer;
        font-weight: 700;
        list-style-position: inside;
    }
    .faq-item summary:hover {
        color: var(--accent-color);
    }
    .faq-item p {
        margin: 0.6em 0 0;
        color: var(--black-mica-2);
    }

    /* Data-friendly table styling */
    :global(.prose table) {
        width: 100%;
        border-collapse: collapse;
        margin: 2em 0;
    }
    :global(.prose th) {
        background-color: var(--text-color);
        color: var(--bg-color);
        padding: 0.75em;
        text-align: left;
    }
    :global(.prose td) {
        border: 1px solid #E5E5E5;
        padding: 0.75em;
    }
</style>
